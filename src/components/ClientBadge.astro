---
/**
 * ClientBadge — styled typographic/SVG badge for partner logos.
 *
 * The PNG files under the /media/clients/ folders were corrupt on
 * delivery (blank, or containing unrelated screenshots). Until clean
 * brand assets are dropped in, we render each partner as a deliberate
 * editorial badge: a small decorative SVG mark + the wordmark typography
 * in the partner's actual brand style (Mon Boum oval, Reno Bat building,
 * Hookah Center chicha, etc.).
 *
 * Each badge is self-contained and uses `currentColor` so the parent
 * tile can paint the whole thing in any color scheme. No external images.
 *
 * Known brand identities are rendered faithfully; unknown partners fall
 * back to a clean italic serif label on a sable hairline background.
 */
interface Props {
	name: string;
	label?: string;
	class?: string;
}

const { name, label, class: className = "" } = Astro.props;
const displayLabel = label ?? name;
---

<div class:list={["client-badge", className]} data-brand={name.toLowerCase().replace(/\s+/g, "-")} title={name}>
	{name === "Mon Boum" && (
		<svg viewBox="0 0 240 120" class="cb-svg" aria-label="Mon Boum">
			<ellipse cx="120" cy="60" rx="110" ry="50" fill="none" stroke="currentColor" stroke-width="2.5" />
			<ellipse cx="120" cy="60" rx="90" ry="38" fill="currentColor" opacity="0.05" />
			<text x="120" y="42" text-anchor="middle" class="cb-t cb-t--cursive">Mon</text>
			<text x="120" y="82" text-anchor="middle" class="cb-t cb-t--display">
				<tspan fill="#D7263D" font-weight="800">B</tspan><tspan>oum</tspan>
			</text>
		</svg>
	)}

	{name === "Reno Bat Invest & Conseil" && (
		<svg viewBox="0 0 240 120" class="cb-svg" aria-label="Reno Bat Invest & Conseil">
			<g class="cb-buildings">
				<rect x="96" y="18" width="18" height="56" fill="currentColor" />
				<rect x="118" y="8" width="22" height="66" fill="currentColor" opacity="0.9" />
				<rect x="144" y="26" width="16" height="48" fill="currentColor" opacity="0.75" />
			</g>
			<rect x="88" y="10" width="84" height="72" fill="none" stroke="currentColor" stroke-width="1.5" />
			<text x="120" y="100" text-anchor="middle" class="cb-t cb-t--display" font-weight="700">RENO BAT</text>
			<text x="120" y="114" text-anchor="middle" class="cb-t cb-t--small">INVEST &amp; CONSEIL</text>
		</svg>
	)}

	{name === "Hookah Center" && (
		<svg viewBox="0 0 240 120" class="cb-svg" aria-label="Hookah Center">
			<g class="cb-hookah" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
				<path d="M118 14 L122 14 L122 22 L130 22 L130 30 L110 30 L110 22 L118 22 Z" fill="currentColor" />
				<path d="M115 30 L125 30 L128 42 L112 42 Z" fill="currentColor" />
				<path d="M108 42 Q 108 58 120 62 Q 132 58 132 42 Z" fill="currentColor" opacity="0.85" />
				<path d="M132 50 Q 148 50 148 62 Q 148 72 140 72" />
			</g>
			<text x="120" y="98" text-anchor="middle" class="cb-t cb-t--display" font-weight="600" letter-spacing="0.04em">HOOKAH</text>
			<text x="120" y="112" text-anchor="middle" class="cb-t cb-t--small">CENTER</text>
		</svg>
	)}

	{name === "Carrosserie AMD" && (
		<svg viewBox="0 0 240 120" class="cb-svg" aria-label="Carrosserie AMD">
			<g stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round">
				<path d="M60 70 Q 78 50 120 50 Q 162 50 180 70" />
				<rect x="70" y="68" width="100" height="14" rx="4" fill="currentColor" opacity="0.15" />
				<circle cx="82" cy="82" r="8" fill="currentColor" />
				<circle cx="158" cy="82" r="8" fill="currentColor" />
				<circle cx="82" cy="82" r="3" fill="#0A0908" />
				<circle cx="158" cy="82" r="3" fill="#0A0908" />
			</g>
			<text x="120" y="106" text-anchor="middle" class="cb-t cb-t--display" font-weight="800">AMD</text>
			<text x="120" y="118" text-anchor="middle" class="cb-t cb-t--small">CARROSSERIE</text>
		</svg>
	)}

	{name === "Eco Synergy" && (
		<svg viewBox="0 0 240 120" class="cb-svg" aria-label="Eco Synergy">
			<g stroke="currentColor" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round">
				<path d="M100 40 Q 80 50 80 70 Q 80 90 120 92 Q 160 90 160 70 Q 160 50 140 40 Q 120 30 100 40 Z" />
				<path d="M120 50 L120 82" />
				<path d="M110 60 Q 120 66 130 60" />
				<path d="M110 72 Q 120 78 130 72" />
			</g>
			<text x="120" y="112" text-anchor="middle" class="cb-t cb-t--display" font-weight="600" letter-spacing="0.05em">ECO SYNERGY</text>
		</svg>
	)}

	{name === "Subway" && (
		<svg viewBox="0 0 240 120" class="cb-svg" aria-label="Subway">
			<text x="120" y="72" text-anchor="middle" class="cb-t cb-t--display" font-weight="800" letter-spacing="-0.03em" font-size="48">SUBWAY</text>
			<path d="M38 80 L 86 72" stroke="#008C15" stroke-width="6" stroke-linecap="round" />
			<path d="M154 72 L 202 80" stroke="#FFC600" stroke-width="6" stroke-linecap="round" />
		</svg>
	)}

	{name === "Adidas" && (
		<svg viewBox="0 0 240 120" class="cb-svg" aria-label="Adidas">
			<g stroke="currentColor" stroke-width="4" stroke-linecap="round">
				<path d="M80 70 L96 36" />
				<path d="M96 70 L112 36" />
				<path d="M112 70 L128 36" />
				<path d="M80 76 L132 76" />
			</g>
			<text x="120" y="106" text-anchor="middle" class="cb-t cb-t--display" font-weight="700" letter-spacing="0.02em">adidas</text>
		</svg>
	)}

	{name === "Sofiane Oumiha" && (
		<svg viewBox="0 0 240 120" class="cb-svg" aria-label="Sofiane Oumiha">
			<g stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
				<circle cx="78" cy="50" r="16" />
				<path d="M62 66 L62 82 L94 82 L94 66" />
				<path d="M120 50 L 210 50 M 120 72 L 190 72" />
			</g>
			<text x="120" y="106" text-anchor="start" class="cb-t cb-t--cursive" font-weight="500">Sofiane Oumiha</text>
		</svg>
	)}

	{name === "Oniris Communication" && (
		<svg viewBox="0 0 240 120" class="cb-svg" aria-label="Oniris Communication">
			<g stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round">
				<circle cx="60" cy="60" r="22" />
				<circle cx="60" cy="60" r="8" fill="currentColor" />
				<path d="M86 52 Q 92 60 86 68" />
				<path d="M96 46 Q 108 60 96 74" />
			</g>
			<text x="120" y="64" text-anchor="start" class="cb-t cb-t--display" font-weight="700" letter-spacing="0.12em">ONIRIS</text>
			<text x="120" y="80" text-anchor="start" class="cb-t cb-t--small" letter-spacing="0.18em">COMMUNICATION</text>
		</svg>
	)}

	{name === "Recupp Sport" && (
		<svg viewBox="0 0 240 120" class="cb-svg" aria-label="Recupp Sport">
			<g stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round">
				<path d="M60 40 L60 80 M60 60 L86 60 M86 40 L86 80 M106 40 Q 106 80 120 80 Q 134 80 134 40" />
			</g>
			<text x="120" y="100" text-anchor="middle" class="cb-t cb-t--display" font-weight="700" letter-spacing="0.05em">RECUPP SPORT</text>
		</svg>
	)}

	{!([
		"Mon Boum",
		"Reno Bat Invest & Conseil",
		"Hookah Center",
		"Carrosserie AMD",
		"Eco Synergy",
		"Subway",
		"Adidas",
		"Sofiane Oumiha",
		"Oniris Communication",
		"Recupp Sport",
	].includes(name)) && (
		<span class="cb-fallback">{displayLabel}</span>
	)}
</div>

<style>
	.client-badge {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		color: currentColor;
	}
	.cb-svg {
		width: 100%;
		height: 100%;
		max-width: 14rem;
		max-height: 5.5rem;
	}
	.cb-t {
		fill: currentColor;
		font-family: var(--font-display, "Fraunces", serif);
	}
	.cb-t--display {
		font-size: 22px;
	}
	.cb-t--small {
		font-size: 10px;
		letter-spacing: 0.15em;
		font-family: var(--font-sans, "Inter", sans-serif);
		font-weight: 500;
	}
	.cb-t--cursive {
		font-size: 18px;
		font-style: italic;
		font-family: var(--font-display, "Fraunces", serif);
	}
	.cb-fallback {
		font-family: var(--font-display, "Fraunces", serif);
		font-style: italic;
		font-size: clamp(1.1rem, 1.4vw, 1.5rem);
		letter-spacing: -0.01em;
		color: currentColor;
		white-space: nowrap;
		font-weight: 500;
	}
</style>
