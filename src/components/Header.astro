---
import Brand from "./Brand.astro";
import { nav, site } from "../lib/site";
---

<header id="site-header" class="site-header" data-state="top">
	<div class="site-header__inner">
		<a class="site-header__brand" href="/" aria-label={`${site.name} — Accueil`}>
			<Brand variant="wordmark" class="site-header__logo" />
		</a>

		<nav class="site-header__nav" aria-label="Navigation principale">
			<ul>
				{nav.map((item) => (
					<li>
						<a href={item.href} data-nav>{item.label}</a>
					</li>
				))}
			</ul>
		</nav>

		<div class="site-header__actions">
			<button
				type="button"
				class="theme-toggle"
				aria-label="Basculer le thème clair / sombre"
				data-theme-toggle
			>
				<svg class="i-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
					<circle cx="12" cy="12" r="4" />
					<path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke-linecap="round" />
				</svg>
				<svg class="i-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke-linejoin="round" />
				</svg>
			</button>

			<a class="cta cta--ghost" href="#contact">Faire une demande</a>

			<button
				type="button"
				class="burger"
				aria-label="Ouvrir le menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
				data-burger
			>
				<span></span>
				<span></span>
			</button>
		</div>
	</div>

	<div
		id="mobile-menu"
		class="mobile-menu"
		role="dialog"
		aria-modal="true"
		aria-label="Menu de navigation mobile"
		data-mobile-menu
		hidden
	>
		<div class="mobile-menu__topbar">
			<a class="mobile-menu__brand" href="/" aria-label={`${site.name} — Accueil`}>
				<Brand variant="wordmark" />
			</a>
			<button
				type="button"
				class="mobile-menu__close"
				aria-label="Fermer le menu"
				data-menu-close
			>
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
					<path d="M6 6l12 12M18 6l-12 12" />
				</svg>
			</button>
		</div>
		<nav class="mobile-menu__nav" aria-label="Navigation mobile">
			<ul>
				{nav.map((item, i) => (
					<li style={`--i:${i}`}>
						<a href={item.href} data-nav-mobile>
							<span class="mobile-menu__num" aria-hidden="true">0{i + 1}</span>
							<span>{item.label}</span>
							<svg class="mobile-menu__chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M5 12h14M13 5l7 7-7 7" />
							</svg>
						</a>
					</li>
				))}
			</ul>
		</nav>
		<div class="mobile-menu__footer">
			<a class="cta" href="#contact" data-nav-mobile>Faire une demande</a>
			<a class="mobile-menu__contact" href={`mailto:${site.email}`}>{site.email}</a>
			<a class="mobile-menu__contact" href={`tel:${site.phone}`}>{site.phoneFormatted}</a>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 50;
		height: var(--header-height);
		display: flex;
		align-items: center;
		transition:
			background-color 0.4s var(--ease-emphatic),
			border-color 0.4s var(--ease-emphatic),
			backdrop-filter 0.4s var(--ease-emphatic);
		border-bottom: 1px solid transparent;
	}

	.site-header[data-state="scrolled"] {
		background: var(--bg-overlay);
		backdrop-filter: saturate(180%) blur(16px);
		-webkit-backdrop-filter: saturate(180%) blur(16px);
		border-bottom-color: var(--border);
	}

	.site-header__inner {
		width: var(--container);
		margin-inline: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
	}

	.site-header__brand {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--text);
		font-family: var(--font-display);
		font-size: 1.4rem;
		line-height: 1;
		letter-spacing: -0.01em;
		transition: color 0.2s;
	}
	.site-header__brand:hover {
		color: var(--accent);
	}
	/* Size lives inside Brand.astro on `.brand--wordmark` because Astro
	 * scoped CSS hashes don't cross component boundaries; a rule declared
	 * here on `.site-header__logo` never reaches the <span> rendered by
	 * the Brand component. Leaving this class as a no-op semantic hook. */

	.site-header__nav {
		display: none;
	}
	@media (min-width: 1024px) {
		.site-header__nav {
			display: block;
		}
		.site-header__nav ul {
			display: flex;
			gap: 2rem;
			list-style: none;
			padding: 0;
			margin: 0;
		}
		.site-header__nav a {
			font-size: 0.875rem;
			font-weight: 500;
			color: var(--text-muted);
			padding: 0.5rem 0;
			position: relative;
			transition: color 0.2s;
		}
		.site-header__nav a::after {
			content: "";
			position: absolute;
			left: 0;
			right: 0;
			bottom: -2px;
			height: 1px;
			background: var(--accent);
			transform: scaleX(0);
			transform-origin: left;
			transition: transform 0.4s var(--ease-emphatic);
		}
		.site-header__nav a:hover {
			color: var(--text);
		}
		.site-header__nav a:hover::after {
			transform: scaleX(1);
		}
	}

	.site-header__actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.theme-toggle {
		width: 2.25rem;
		height: 2.25rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--text-muted);
		transition: color 0.2s, border-color 0.2s, background 0.2s;
		flex-shrink: 0;
	}
	.theme-toggle:hover {
		color: var(--accent);
		border-color: var(--accent);
	}
	.theme-toggle .i-sun { display: none; }
	.theme-toggle .i-moon { display: block; }
	:root[data-theme="light"] .theme-toggle .i-sun,
	:root:not([data-theme]) .theme-toggle .i-moon { display: block; }
	:root[data-theme="light"] .theme-toggle .i-moon,
	:root:not([data-theme]) .theme-toggle .i-sun { display: none; }
	@media (prefers-color-scheme: light) {
		:root:not([data-theme]) .theme-toggle .i-moon { display: none; }
		:root:not([data-theme]) .theme-toggle .i-sun { display: block; }
	}

	.cta {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.625rem 1.125rem;
		background: var(--accent);
		color: var(--text-inverted);
		border-radius: 999px;
		font-size: 0.875rem;
		font-weight: 500;
		letter-spacing: -0.01em;
		transition: transform 0.3s var(--ease-emphatic), background 0.2s;
		white-space: nowrap;
	}
	.cta:hover {
		transform: translateY(-1px);
		background: var(--color-sienne-deep);
	}
	.cta--ghost {
		background: transparent;
		color: var(--text);
		border: 1px solid var(--border-strong);
	}
	.cta--ghost:hover {
		background: var(--accent);
		color: var(--text-inverted);
		border-color: var(--accent);
	}
	@media (max-width: 640px) {
		.cta--ghost {
			display: none;
		}
	}

	.burger {
		display: inline-flex;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		width: 2.25rem;
		height: 2.25rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		align-items: center;
		flex-shrink: 0;
	}
	.burger span {
		display: block;
		height: 1.5px;
		width: 14px;
		background: var(--text);
		transition: transform 0.3s var(--ease-emphatic);
	}
	@media (min-width: 1024px) {
		.burger {
			display: none;
		}
	}

	/* Burger active state */
	.burger[aria-expanded="true"] span:nth-child(1) {
		transform: translateY(3.5px) rotate(45deg);
	}
	.burger[aria-expanded="true"] span:nth-child(2) {
		transform: translateY(-3px) rotate(-45deg);
	}

	/* ----- Mobile menu drawer --------------------------------------- */
	/* The drawer always paints on a dark warm surface regardless of
	 * the site theme so it stays legible above any section (cream,
	 * warm-dark, etc.). A backdrop blur softens whatever is beneath. */
	.mobile-menu {
		position: fixed;
		inset: 0;
		background: #0A0908;
		color: #F2EEE5;
		z-index: 60;
		display: flex;
		flex-direction: column;
		padding: 1rem 1.25rem 1.5rem;
		opacity: 0;
		pointer-events: none;
		transition:
			opacity 0.4s var(--ease-emphatic),
			transform 0.5s var(--ease-emphatic);
		transform: translateY(-2%);
		backdrop-filter: saturate(160%) blur(22px);
		-webkit-backdrop-filter: saturate(160%) blur(22px);
		overflow-y: auto;
		gap: 2rem;
	}
	.mobile-menu[data-open="true"] {
		opacity: 1;
		pointer-events: auto;
		transform: translateY(0);
	}

	/* Aubergine radial accent in the bottom-right corner to tie the
	 * drawer into the site's cool-accent palette. */
	.mobile-menu::before {
		content: "";
		position: absolute;
		inset: 0;
		background: radial-gradient(
			circle at 90% 85%,
			color-mix(in oklab, var(--accent-cool) 32%, transparent) 0%,
			transparent 45%
		);
		pointer-events: none;
	}
	.mobile-menu > * {
		position: relative;
		z-index: 1;
	}

	/* Top bar: brand wordmark on the left, explicit × close on the right. */
	.mobile-menu__topbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		height: var(--header-height);
	}
	.mobile-menu__brand {
		display: inline-flex;
		align-items: center;
		color: #F2EEE5;
	}
	.mobile-menu__close {
		width: 2.75rem;
		height: 2.75rem;
		border: 1px solid color-mix(in oklab, #F2EEE5 25%, transparent);
		border-radius: 999px;
		background: color-mix(in oklab, #F2EEE5 6%, transparent);
		color: #F2EEE5;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		transition:
			background 0.3s var(--ease-soft),
			border-color 0.3s var(--ease-soft),
			transform 0.35s var(--ease-emphatic);
	}
	.mobile-menu__close:hover {
		background: var(--accent-cool);
		border-color: var(--accent-cool);
		transform: rotate(90deg);
	}

	/* Navigation: each item is a row with a two-digit counter, label and
	 * an arrow that slides right on hover. Staggered slide-in on open. */
	.mobile-menu__nav {
		flex: 1;
		display: flex;
		align-items: center;
	}
	.mobile-menu__nav ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		width: 100%;
	}
	.mobile-menu__nav a {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		font-family: var(--font-display);
		font-size: clamp(2.25rem, 9vw, 4rem);
		font-weight: 400;
		font-variation-settings: "opsz" 144, "SOFT" 30;
		line-height: 1.05;
		padding: 0.55rem 0;
		color: #F2EEE5;
		opacity: 0;
		transform: translateY(24px);
		transition:
			opacity 0.55s var(--ease-emphatic) calc(var(--i, 0) * 0.06s + 0.18s),
			transform 0.55s var(--ease-emphatic) calc(var(--i, 0) * 0.06s + 0.18s),
			color 0.25s var(--ease-soft);
		border-bottom: 1px solid color-mix(in oklab, #F2EEE5 10%, transparent);
	}
	.mobile-menu__num {
		font-family: var(--font-mono, ui-monospace, monospace);
		font-size: 0.75rem;
		letter-spacing: 0.12em;
		color: color-mix(in oklab, #F2EEE5 45%, transparent);
		flex-shrink: 0;
		width: 2rem;
		font-style: normal;
		font-variation-settings: normal;
	}
	.mobile-menu__chev {
		margin-left: auto;
		color: color-mix(in oklab, #F2EEE5 40%, transparent);
		transform: translateX(-6px);
		opacity: 0;
		transition: transform 0.35s var(--ease-emphatic), opacity 0.3s var(--ease-soft), color 0.3s var(--ease-soft);
		flex-shrink: 0;
		align-self: center;
	}
	.mobile-menu[data-open="true"] .mobile-menu__nav a {
		opacity: 1;
		transform: translateY(0);
	}
	.mobile-menu__nav a:hover,
	.mobile-menu__nav a:focus-visible {
		color: var(--accent-cool);
		font-style: italic;
	}
	.mobile-menu__nav a:hover .mobile-menu__chev,
	.mobile-menu__nav a:focus-visible .mobile-menu__chev {
		transform: translateX(0);
		opacity: 1;
		color: var(--accent-cool);
	}

	/* Footer: CTA + direct channels. */
	.mobile-menu__footer {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: flex-start;
		padding-top: 1rem;
		border-top: 1px solid color-mix(in oklab, #F2EEE5 12%, transparent);
	}
	.mobile-menu__footer .cta {
		background: var(--accent-cool);
		color: #F2EEE5;
	}
	.mobile-menu__footer .cta:hover {
		background: #F2EEE5;
		color: #0A0908;
	}
	.mobile-menu__contact {
		font-size: 0.9rem;
		color: color-mix(in oklab, #F2EEE5 70%, transparent);
		font-variant-numeric: tabular-nums;
	}
	.mobile-menu__contact:hover {
		color: var(--accent-cool);
	}

	@media (prefers-reduced-motion: reduce) {
		.mobile-menu,
		.mobile-menu__nav a,
		.mobile-menu__chev,
		.mobile-menu__close {
			transition: none !important;
		}
		.mobile-menu[data-open="true"] .mobile-menu__nav a {
			opacity: 1;
			transform: none;
		}
	}
</style>

<script>
	/**
	 * Header script: scroll state, theme toggle, and mobile menu drawer.
	 *
	 * The drawer is driven by a single `toggleMenu(open)` function which is
	 * also exposed on `window.__idskillzToggleMenu` so the floating MENU
	 * button in `Fab.astro` can open the same drawer. The burger icon and
	 * the FAB button both act as triggers; the header's X button and ESC
	 * act as closers.
	 */
	const header = document.getElementById("site-header");
	const themeBtn = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
	const burger = document.querySelector<HTMLButtonElement>("[data-burger]");
	const mobileMenu = document.querySelector<HTMLDivElement>("[data-mobile-menu]");
	const closeBtn = document.querySelector<HTMLButtonElement>("[data-menu-close]");

	// Header scroll state (top vs scrolled for background blur)
	const updateState = () => {
		if (!header) return;
		header.dataset.state = window.scrollY > 24 ? "scrolled" : "top";
	};
	window.addEventListener("scroll", updateState, { passive: true });
	updateState();

	// Theme toggle (persists in localStorage)
	themeBtn?.addEventListener("click", () => {
		const root = document.documentElement;
		const current =
			root.dataset.theme ??
			(window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
		const next = current === "light" ? "dark" : "light";
		root.dataset.theme = next;
		try {
			localStorage.setItem("idskillz-theme", next);
		} catch (_) {}
	});

	// Mobile drawer controller, exposed globally so the FAB MENU button
	// can call it too (see Fab.astro).
	const toggleMenu = (open: boolean) => {
		if (!mobileMenu) return;
		mobileMenu.dataset.open = String(open);
		mobileMenu.hidden = !open;
		document.body.style.overflow = open ? "hidden" : "";
		burger?.setAttribute("aria-expanded", String(open));
		const fabMenu = document.querySelector<HTMLButtonElement>(
			".fab [data-fab-action='menu']",
		);
		fabMenu?.setAttribute("aria-expanded", String(open));
	};
	// Expose to the global scope for cross-component wiring.
	(window as unknown as { __idskillzToggleMenu?: (open: boolean) => void })
		.__idskillzToggleMenu = toggleMenu;

	burger?.addEventListener("click", () => {
		toggleMenu(burger.getAttribute("aria-expanded") !== "true");
	});
	closeBtn?.addEventListener("click", () => toggleMenu(false));
	document.querySelectorAll("[data-nav-mobile]").forEach((a) =>
		a.addEventListener("click", () => toggleMenu(false)),
	);
	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") toggleMenu(false);
	});
</script>
