---
import Brand from "./Brand.astro";
import { nav, site } from "../lib/site";
---

<header id="site-header" class="site-header" data-state="top">
	<div class="site-header__inner">
		<a class="site-header__brand" href="/" aria-label={`${site.name} — Accueil`}>
			<Brand variant="wordmark" class="site-header__logo" />
		</a>

		<nav class="site-header__nav" aria-label="Navigation principale">
			<ul>
				{nav.map((item, i) => (
					<li>
						<a href={item.href} data-nav>
							<span class="nav-num">// 0{i + 1}</span>
							{item.label}
						</a>
					</li>
				))}
			</ul>
		</nav>

		<div class="site-header__actions">
			<a class="btn-hud btn-hud-primary" href="#contact">Nous_Contacter</a>

			<button
				type="button"
				class="burger"
				aria-label="Ouvrir le menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
				data-burger
			>
				<span></span>
				<span></span>
			</button>
		</div>
	</div>

	<div
		id="mobile-menu"
		class="mobile-menu"
		role="dialog"
		aria-modal="true"
		aria-label="Menu de navigation mobile"
		data-mobile-menu
	>
		<div class="mobile-menu__topbar">
			<a class="mobile-menu__brand" href="/" aria-label={`${site.name} — Accueil`}>
				<Brand variant="wordmark" />
			</a>
			<button
				type="button"
				class="mobile-menu__close"
				aria-label="Fermer le menu"
				data-menu-close
			>
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
					<path d="M6 6l12 12M18 6l-12 12" />
				</svg>
			</button>
		</div>
		<nav class="mobile-menu__nav" aria-label="Navigation mobile">
			<ul>
				{nav.map((item, i) => (
					<li style={`--i:${i}`}>
						<a href={item.href} data-nav-mobile>
							<span class="mobile-menu__num" aria-hidden="true">// 0{i + 1}</span>
							<span>{item.label}</span>
							<svg class="mobile-menu__chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M5 12h14M13 5l7 7-7 7" />
							</svg>
						</a>
					</li>
				))}
			</ul>
		</nav>
		<div class="mobile-menu__footer">
			<a class="btn-hud" href="#contact" data-nav-mobile style="width: 100%; justify-content: center;">Initialiser_Projet</a>
			<div class="mobile-menu__meta">
				<a href={`mailto:${site.email}`}>{site.email}</a>
				<a href={`tel:${site.phone}`}>{site.phoneFormatted}</a>
			</div>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 80;
		height: var(--header-height);
		display: flex;
		align-items: center;
		transition: all 0.4s var(--ease-emphatic);
		border-bottom: 1px solid transparent;
	}

	.site-header[data-state="scrolled"] {
		background: rgba(8, 8, 8, 0.8);
		backdrop-filter: blur(12px);
		border-bottom-color: var(--border);
	}

	.site-header__inner {
		width: var(--container);
		margin-inline: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
	}

	.site-header__brand {
		transition: opacity 0.3s;
	}
	.site-header__brand:hover {
		opacity: 0.7;
	}

	.site-header__nav {
		display: none;
	}
	@media (min-width: 1024px) {
		.site-header__nav {
			display: block;
		}
		.site-header__nav ul {
			display: flex;
			gap: 3rem;
			list-style: none;
		}
		.site-header__nav a {
			font-family: var(--font-mono);
			font-size: 0.65rem;
			font-weight: 500;
			letter-spacing: 0.2em;
			text-transform: uppercase;
			color: var(--text-muted);
			display: flex;
			flex-direction: column;
			gap: 0.25rem;
			transition: color 0.3s;
		}
		.nav-num {
			font-size: 0.55rem;
			color: var(--tech);
			opacity: 0.5;
		}
		.site-header__nav a:hover {
			color: #fff;
		}
	}

	.site-header__actions {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.burger {
		width: 2.5rem;
		height: 2.5rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: flex-end;
		gap: 6px;
		padding: 0.5rem;
	}
	.burger span {
		display: block;
		height: 1px;
		background: #fff;
		transition: all 0.3s var(--ease-emphatic);
	}
	.burger span:nth-child(1) { width: 1.5rem; }
	.burger span:nth-child(2) { width: 1rem; }

	@media (min-width: 1024px) {
		.burger { display: none; }
	}

	.burger[aria-expanded="true"] span:nth-child(1) {
		transform: translateY(3.5px) rotate(45deg);
		width: 1.2rem;
	}
	.burger[aria-expanded="true"] span:nth-child(2) {
		transform: translateY(-3.5px) rotate(-45deg);
		width: 1.2rem;
	}

	/* Mobile Menu */
	.mobile-menu {
		position: fixed;
		inset: 0;
		background: #080808;
		z-index: 90;
		display: flex;
		flex-direction: column;
		padding: 1.5rem;
		opacity: 0;
		pointer-events: none;
		transform: translateY(-10px);
		transition: all 0.5s var(--ease-emphatic);
	}
	.mobile-menu[data-open="true"] {
		opacity: 1;
		pointer-events: auto;
		transform: translateY(0);
	}

	.mobile-menu__topbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		height: var(--header-height);
	}

	.mobile-menu__close {
		width: 3rem;
		height: 3rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--border);
		color: #fff;
	}

	.mobile-menu__nav {
		flex: 1;
		display: flex;
		align-items: center;
	}
	.mobile-menu__nav ul {
		width: 100%;
		list-style: none;
	}
	.mobile-menu__nav a {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 10vw, 5rem);
		font-weight: 800;
		text-transform: uppercase;
		line-height: 0.95;
		padding-block: 1rem;
		border-bottom: 1px solid var(--border);
		opacity: 0;
		transform: translateX(-20px);
		transition: all 0.5s var(--ease-emphatic) calc(var(--i) * 0.1s + 0.2s);
	}
	.mobile-menu[data-open="true"] .mobile-menu__nav a {
		opacity: 1;
		transform: translateX(0);
	}

	.mobile-menu__num {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--tech);
		font-weight: 400;
	}

	.mobile-menu__footer {
		padding-top: 2rem;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.mobile-menu__meta {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--text-soft);
	}
</style>

<script>
	/**
	 * Header script: scroll state, theme toggle, and mobile menu drawer.
	 *
	 * The drawer is driven by a single `toggleMenu(open)` function which is
	 * also exposed on `window.__idskillzToggleMenu` so the floating MENU
	 * button in `Fab.astro` can open the same drawer. The burger icon and
	 * the FAB button both act as triggers; the header's X button and ESC
	 * act as closers.
	 */
	const header = document.getElementById("site-header");
	const themeBtn = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
	const burger = document.querySelector<HTMLButtonElement>("[data-burger]");
	const mobileMenu = document.querySelector<HTMLDivElement>("[data-mobile-menu]");
	const closeBtn = document.querySelector<HTMLButtonElement>("[data-menu-close]");

	// Header scroll state (top vs scrolled for background blur)
	const updateState = () => {
		if (!header) return;
		header.dataset.state = window.scrollY > 24 ? "scrolled" : "top";
	};
	window.addEventListener("scroll", updateState, { passive: true });
	updateState();

	// Theme toggle (persists in localStorage)
	themeBtn?.addEventListener("click", () => {
		const root = document.documentElement;
		const current =
			root.dataset.theme ??
			(window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
		const next = current === "light" ? "dark" : "light";
		root.dataset.theme = next;
		try {
			localStorage.setItem("idskillz-theme", next);
		} catch (_) {}
	});

	// Mobile drawer controller, exposed globally so the FAB MENU button
	// can call it too (see Fab.astro).
	const toggleMenu = (open: boolean) => {
		if (!mobileMenu) return;
		mobileMenu.dataset.open = String(open);
		// Don't use mobileMenu.hidden — it adds display:none !important
		// which breaks the CSS opacity/transform transition. Visibility
		// is entirely handled via CSS (opacity + pointer-events).
		document.body.style.overflow = open ? "hidden" : "";
		burger?.setAttribute("aria-expanded", String(open));
		const fabMenu = document.querySelector<HTMLButtonElement>(
			".fab [data-fab-action='menu']",
		);
		fabMenu?.setAttribute("aria-expanded", String(open));
	};
	// Expose to the global scope for cross-component wiring.
	(window as unknown as { __idskillzToggleMenu?: (open: boolean) => void })
		.__idskillzToggleMenu = toggleMenu;

	burger?.addEventListener("click", () => {
		toggleMenu(burger.getAttribute("aria-expanded") !== "true");
	});
	closeBtn?.addEventListener("click", () => toggleMenu(false));
	document.querySelectorAll("[data-nav-mobile]").forEach((a) =>
		a.addEventListener("click", () => toggleMenu(false)),
	);
	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") toggleMenu(false);
	});
</script>
