---
/**
 * Expertises — section "6 modules" mood "warm-dark".
 *
 * Six cards in a horizontal track (scroll-tied on desktop),
 * each featuring technical metadata, monospaced status logs,
 * and sharp HUD framing.
 *
 * Anchor: #expertises
 */

interface Expertise {
	title: string;
	body: string;
	tags: string[];
}

const expertises: Expertise[] = [
	{
		title: "Sites web sur-mesure",
		body: "Sites <strong>vitrines</strong>, <strong>e-commerce</strong> et applications web pensés pour <strong>convertir</strong>. Code propre, performances mesurées, SEO en filigrane.",
		tags: ["Astro", "WordPress", "Shopify", "Next.js"],
	},
	{
		title: "Identité visuelle",
		body: "<strong>Logo</strong>, charte graphique, naming, déclinaisons. Une marque qui tient en mouvement comme à l'arrêt — papier, écran ou vitrine.",
		tags: ["Logotype", "Charte", "Brand book"],
	},
	{
		title: "Design digital & print",
		body: "Brochures, plaquettes, packagings, signalétique, <strong>templates</strong> de communication. Une cohérence visuelle de l'écran au support imprimé.",
		tags: ["Print", "Édition", "Packaging"],
	},
	{
		title: "Vidéo de marque",
		body: "<strong>Films institutionnels</strong>, capsules sociales, <strong>motion design</strong>, étalonnage. De l'écriture au mix, on garde la main de bout en bout.",
		tags: ["Réalisation", "Motion", "Mix son"],
	},
	{
		title: "Drone & événementiel",
		body: "Captations <strong>aériennes</strong>, événements sportifs, retransmissions live. Pilotes <strong>certifiés</strong>, autorisations vol et suivi technique inclus.",
		tags: ["Drone S1·S2", "Live", "Sport"],
	},
	{
		title: "3D & rendus immobiliers",
		body: "<strong>Modélisation</strong>, perspectives photoréalistes, animations d'architecture, rendus produits. Pour vendre un programme avant la première brique.",
		tags: ["Archi-viz", "Rendu 3D", "Animation"],
	},
];
---

<section
	id="expertises"
	class="exp section-warm-dark"
	data-section-mood="warm-dark"
	aria-labelledby="exp-title"
	data-scroll-tied
>
	<header class="exp__header section-pad-top">
		<p class="eyebrow reveal"><span class="eyebrow-prefix">///</span> CORE_CAPABILITIES</p>
		<h2 id="exp-title" class="h-1 reveal" style="--delay:.1s">
			Quatre métiers, <span class="mark-gradient">six vecteurs</span> de jeu.
		</h2>
		<p class="exp__lead reveal" style="--delay:.2s">
			De la première ligne de code au dernier rendu 3D, tout est fabriqué
			en interne par la même équipe. Cohérence technique et esthétique absolue.
		</p>
		<p class="exp__hint reveal" style="--delay:.3s" aria-hidden="true">
			<span>SYSTEM_SCAN: EXPLORATION_READY</span>
			<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7" /></svg>
		</p>
	</header>

	<div class="exp__track-wrap">
		<div class="exp__track-stage">
			<ul class="exp__grid exp__track">
				{expertises.map((e, i) => (
					<li
						class="expertise-card reveal corner-brackets"
						style={`--delay:${0.05 * i + 0.15}s`}
					>
						<div class="expertise-card__meta">
							<span class="expertise-card__num">[ MODULE_0{i + 1} ]</span>
							<span class="expertise-card__status">READY</span>
						</div>

						<h3 class="expertise-card__title">{e.title}</h3>
						<p class="expertise-card__body" set:html={e.body}></p>
						
						<ul class="expertise-card__tags">
							{e.tags.map((t) => (
								<li class="tag-pill">{t}</li>
							))}
						</ul>
						
						<div class="expertise-card__bottom">
							<span class="expertise-card__uid">UID: 0x{Math.random().toString(16).slice(2, 6).toUpperCase()}</span>
						</div>
					</li>
				))}
			</ul>
			<div class="exp__progress" aria-hidden="true">
				<div class="exp__progress-fill"></div>
			</div>
		</div>
	</div>

	<footer class="exp__footer reveal section-pad-bottom" style="--delay:.5s">
		<a class="btn-hud" href="#contact">
			Initialiser_Session
		</a>
	</footer>
</section>

<style>
	.exp {
		position: relative;
		background: #080808;
	}
	.exp__header {
		width: var(--container);
		margin-inline: auto;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding-bottom: 2rem;
	}
	.exp__lead {
		max-width: 32rem;
		color: var(--text-muted);
		font-size: 1.1rem;
		line-height: 1.6;
	}

	.exp__track-wrap {
		position: relative;
	}
	.exp__track-stage {
		position: relative;
	}
	.exp__grid {
		width: var(--container);
		margin-inline: auto;
		list-style: none;
		padding: 0;
		display: grid;
		gap: 1.5rem;
		grid-template-columns: 1fr;
	}
	
	@media (min-width: 768px) and (max-width: 1023px) {
		.exp__grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.exp__hint {
		display: none;
	}
	.exp__progress {
		display: none;
	}

	@media (min-width: 1024px) {
		.exp__hint {
			display: inline-flex;
			align-items: center;
			gap: 0.75rem;
			color: var(--tech);
			font-family: var(--font-mono);
			font-size: 0.65rem;
			letter-spacing: 0.1em;
			text-transform: uppercase;
			margin-top: 1rem;
		}
		.exp__hint svg {
			animation: expHintBob 1.8s var(--ease-emphatic) infinite alternate;
		}
		@keyframes expHintBob {
			from { transform: translateY(-2px); }
			to   { transform: translateY(4px); }
		}

		.exp__track-wrap {
			height: 300vh;
		}
		.exp__track-stage {
			position: sticky;
			top: 0;
			height: 100vh;
			overflow: hidden;
			display: flex;
			flex-direction: column;
			justify-content: center;
			gap: 3rem;
		}
		.exp__grid.exp__track {
			width: max-content;
			margin: 0;
			display: flex;
			gap: 2rem;
			padding-inline: clamp(4rem, 10vw, 15vw);
			transform: translate3d(var(--exp-translate, 0px), 0, 0);
			will-change: transform;
		}
		.expertise-card {
			width: 24rem;
			height: 28rem;
			flex-shrink: 0;
		}

		.exp__progress {
			display: block;
			position: relative;
			width: 40rem;
			margin: 0 auto;
			height: 2px;
			background: rgba(255, 255, 255, 0.05);
			overflow: hidden;
		}
		.exp__progress-fill {
			position: absolute;
			inset: 0;
			transform: scaleX(var(--p, 0));
			transform-origin: left center;
			background: var(--tech);
			box-shadow: 0 0 10px var(--tech);
		}
	}

	.expertise-card {
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border);
		padding: 2.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		transition: all 0.4s var(--ease-soft);
	}
	.expertise-card:hover {
		background: rgba(255, 255, 255, 0.05);
		border-color: var(--tech);
	}

	.expertise-card__meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: var(--font-mono);
		font-size: 0.65rem;
		color: var(--tech);
	}

	.expertise-card__title {
		font-size: 1.5rem;
		font-weight: 700;
		color: #fff;
		margin-bottom: 0.5rem;
	}

	.expertise-card__body {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		line-height: 1.6;
		color: var(--text-muted);
		flex: 1;
	}

	.expertise-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		list-style: none;
	}
	.tag-pill {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		padding: 0.3rem 0.75rem;
		border: 1px solid var(--border);
		color: var(--text-soft);
		text-transform: uppercase;
	}

	.expertise-card__bottom {
		margin-top: auto;
		font-family: var(--font-mono);
		font-size: 0.55rem;
		color: var(--text-soft);
		opacity: 0.4;
	}

	.exp__footer {
		display: flex;
		justify-content: center;
		padding-top: 4rem;
	}

	.reveal {
		transition-delay: var(--delay, 0s);
	}
</style>

<script>
	/**
	 * Expertises scroll-tied horizontal track controller.
	 */
	(() => {
		const section = document.querySelector<HTMLElement>(".exp[data-scroll-tied]");
		if (!section) return;
		const wrap = section.querySelector<HTMLElement>(".exp__track-wrap");
		const track = section.querySelector<HTMLElement>(".exp__track");
		if (!wrap || !track) return;

		const desktop = window.matchMedia("(min-width: 1024px)");
		const reduced = window.matchMedia("(prefers-reduced-motion: reduce)");

		let travel = 0;

		const measure = () => {
			if (!desktop.matches || reduced.matches) {
				travel = 0;
				track.style.removeProperty("--exp-translate");
				section.style.removeProperty("--p");
				return;
			}
			travel = Math.max(0, track.scrollWidth - window.innerWidth);
		};

		let ticking = false;
		const onScroll = () => {
			if (ticking) return;
			if (!desktop.matches || reduced.matches) return;
			ticking = true;
			requestAnimationFrame(() => {
				const rect = wrap.getBoundingClientRect();
				const total = rect.height - window.innerHeight;
				if (total <= 0) { ticking = false; return; }
				const raw = Math.max(0, Math.min(1, -rect.top / total));
				section.style.setProperty("--p", raw.toFixed(4));
				track.style.setProperty(
					"--exp-translate",
					`${(-raw * travel).toFixed(2)}px`,
				);
				ticking = false;
			});
		};

		measure();
		onScroll();
		window.addEventListener("scroll", onScroll, { passive: true });
		window.addEventListener("resize", () => {
			measure();
			onScroll();
		});
		desktop.addEventListener("change", () => {
			measure();
			onScroll();
		});
	})();
</script>
