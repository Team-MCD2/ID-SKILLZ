---
import { site } from "../../lib/site";
---

<section id="contact" class="contact section-warm-dark section-pad" data-section-mood="warm-dark" aria-labelledby="contact-title">
	<div class="contact__inner">
		<div class="contact__copy">
			<p class="eyebrow reveal">Démarrer un projet</p>
			<h2 id="contact-title" class="h-1 reveal balance" style="--delay:.1s">
				Une idée ? On est
				<span class="mark-gradient">à 15 minutes de Zoom</span>
				ou d&rsquo;un espresso.
			</h2>
			<p class="contact__lead reveal" style="--delay:.2s">
				Décrivez-nous votre projet en quelques lignes. On vous répond sous 24 h ouvrées
				avec un premier avis franc, gratuit, et sans engagement.
			</p>

			<ul class="contact__channels reveal" style="--delay:.3s">
				<li>
					<span class="ch-label">Email</span>
					<a href={`mailto:${site.email}`}>{site.email}</a>
				</li>
				<li>
					<span class="ch-label">Téléphone</span>
					<a href={`tel:${site.phone}`}>{site.phoneFormatted}</a>
				</li>
				<li>
					<span class="ch-label">Studio</span>
					<a href={site.addresses.toulouse.href} target="_blank" rel="noreferrer">
						16 chemin de Garrabot, Colomiers
					</a>
				</li>
				<li>
					<span class="ch-label">Siège</span>
					<a href={site.addresses.paris.href} target="_blank" rel="noreferrer">
						66 av. des Champs-Élysées, Paris
					</a>
				</li>
			</ul>
		</div>

		<form
			class="contact__form reveal"
			style="--delay:.2s"
			method="POST"
			action={`mailto:${site.email}?subject=${encodeURIComponent("Projet ID Skillz")}`}
			enctype="text/plain"
		>
			<div class="field">
				<label for="name">Votre nom</label>
				<input id="name" name="name" type="text" required autocomplete="name" placeholder="Sami H." />
			</div>
			<div class="field">
				<label for="email">Email</label>
				<input id="email" name="email" type="email" required autocomplete="email" placeholder="vous@exemple.com" />
			</div>
			<div class="field">
				<label for="company">Société (optionnel)</label>
				<input id="company" name="company" type="text" autocomplete="organization" placeholder="Acme Co." />
			</div>
			<div class="field field--inline">
				<span class="legend">Métier souhaité</span>
				<div class="chips" role="group" aria-label="Métier souhaité">
					<label><input type="checkbox" name="services" value="site-web" /><span>Site web</span></label>
					<label><input type="checkbox" name="services" value="design" /><span>Design</span></label>
					<label><input type="checkbox" name="services" value="video" /><span>Vidéo</span></label>
					<label><input type="checkbox" name="services" value="3d" /><span>3D</span></label>
				</div>
			</div>
			<div class="field">
				<label for="message">Votre projet en quelques lignes</label>
				<textarea
					id="message"
					name="message"
					rows="5"
					required
					placeholder="Le contexte, les enjeux, les délais, le budget si vous l’avez déjà…"
				></textarea>
			</div>
			<button type="submit" class="contact__submit">
				<span>Envoyer la demande</span>
				<svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
					<path d="M2 8h12M9 3l5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</button>
			<p class="contact__rgpd">
				En envoyant ce formulaire, vous acceptez que vos informations soient utilisées
				pour vous recontacter dans le cadre de ce projet uniquement.
				<a href="/politique-de-confidentialite">En savoir plus</a>.
			</p>
		</form>
	</div>
</section>

<style>
	.contact {
		position: relative;
		overflow: hidden;
	}

	.contact__inner {
		width: var(--container);
		margin-inline: auto;
		display: grid;
		gap: 3rem;
		grid-template-columns: 1fr;
	}
	@media (min-width: 1024px) {
		.contact__inner {
			grid-template-columns: 1fr 1fr;
			gap: 5rem;
		}
	}

	.contact__copy {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		max-width: 32rem;
	}
	.contact__lead {
		font-size: clamp(1rem, 0.9vw + 0.6rem, 1.15rem);
		color: var(--text-muted);
		line-height: 1.65;
	}
	.contact__channels {
		list-style: none;
		padding: 1.5rem 0 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		border-top: 1px solid var(--border);
	}
	.contact__channels li {
		display: grid;
		grid-template-columns: 6rem 1fr;
		align-items: baseline;
		gap: 1rem;
		font-size: 0.9rem;
	}
	.ch-label {
		font-size: 0.7rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-soft);
	}
	.contact__channels a {
		color: var(--text);
		transition: color 0.2s;
	}
	.contact__channels a:hover {
		color: var(--accent);
	}

	/* Form */
	.contact__form {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 1.75rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 1.25rem;
	}
	.field {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	.field label,
	.legend {
		font-size: 0.7rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-soft);
	}
	.field input,
	.field textarea {
		font: inherit;
		color: var(--text);
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 0.5rem;
		padding: 0.75rem 0.875rem;
		font-size: 0.95rem;
		transition: border-color 0.2s, background 0.2s;
	}
	.field input:focus,
	.field textarea:focus {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
		border-color: var(--accent);
	}
	.field input::placeholder,
	.field textarea::placeholder {
		color: var(--text-soft);
	}

	.chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}
	.chips label {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.45rem 0.85rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		font-size: 0.85rem;
		color: var(--text-muted);
		cursor: pointer;
		transition: all 0.2s;
		text-transform: none;
		letter-spacing: 0;
	}
	.chips label:hover {
		border-color: var(--border-strong);
		color: var(--text);
	}
	.chips label:has(input:checked) {
		background: var(--text);
		color: var(--text-inverted);
		border-color: var(--text);
	}
	.chips input {
		display: none;
	}

	.contact__submit {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 1rem;
		background: var(--accent);
		color: var(--text-inverted);
		border-radius: 0.5rem;
		font-size: 0.95rem;
		font-weight: 500;
		transition: background 0.2s, transform 0.3s var(--ease-emphatic);
		margin-top: 0.5rem;
	}
	.contact__submit:hover {
		background: var(--color-sienne-deep);
		transform: translateY(-1px);
	}

	.contact__rgpd {
		font-size: 0.75rem;
		color: var(--text-soft);
		line-height: 1.55;
	}
	.contact__rgpd a {
		color: var(--accent);
		border-bottom: 1px solid currentColor;
	}

	.reveal {
		transition-delay: var(--delay, 0s);
	}
</style>
