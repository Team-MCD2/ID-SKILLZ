---
/**
 * Reviews — section "avis Google" mood "cream".
 *
 * Cream-paper editorial header (eyebrow + big serif title + lead with
 * average score and link) on top of an Embla horizontal carousel of
 * verified Google reviews. Each card is a paper testimonial with stars,
 * a serif italic quote, and a cite line; hover lifts the card slightly.
 *
 * Anchor: #avis
 */
import ReviewsCarousel from "../islands/ReviewsCarousel";
import { reviews, site } from "../../lib/site";

const avg =
	Math.round(
		(reviews.reduce((acc, r) => acc + r.rating, 0) / reviews.length) * 10,
	) / 10;

const googleUrl = site.socials.google;
---

<section
	id="avis"
	class="reviews section-cream section-pad"
	data-section-mood="cream"
	aria-labelledby="reviews-title"
>
	<header class="reviews__header">
		<p class="eyebrow reveal">Avis clients · Vérifiés sur Google</p>
		<h2 id="reviews-title" class="h-1 reveal balance" style="--delay:.1s">
			Nos clients
			<span class="mark-gradient">en parlent mieux</span>
			que nous.
		</h2>
		<p class="reviews__lead reveal" style="--delay:.2s">
			Une moyenne de <strong>{avg.toFixed(1)} / 5</strong> sur Google.
			Les retours bruts, sans filtre&nbsp;:
		</p>

		<a
			class="reviews__google reveal"
			href={googleUrl}
			target="_blank"
			rel="noreferrer"
			style="--delay:.3s"
			aria-label="Voir toutes nos évaluations sur Google (ouvre dans un nouvel onglet)"
		>
			<span class="reviews__google-icon" aria-hidden="true">
				<svg viewBox="0 0 48 48" width="16" height="16">
					<path fill="#4285F4" d="M43.6 20.5H42V20H24v8h11.3C33.6 32.7 29.2 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3 0 5.7 1.1 7.8 2.9l5.7-5.7C34.1 6.1 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.2-.1-2.3-.4-3.5z" />
					<path fill="#34A853" d="M6.3 14.7l6.6 4.8C14.7 15.1 19 12 24 12c3 0 5.7 1.1 7.8 2.9l5.7-5.7C34.1 6.1 29.3 4 24 4 16.3 4 9.7 8.4 6.3 14.7z" />
					<path fill="#FBBC05" d="M24 44c5.2 0 9.9-2 13.4-5.2l-6.2-5.2c-2 1.4-4.5 2.2-7.2 2.2-5.2 0-9.6-3.3-11.3-8l-6.5 5C9.5 39.5 16.2 44 24 44z" />
					<path fill="#EA4335" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.3-2.3 4.2-4.1 5.6l6.2 5.2C41.2 35.4 44 30.1 44 24c0-1.2-.1-2.3-.4-3.5z" />
				</svg>
			</span>
			<span>Voir sur Google</span>
			<svg viewBox="0 0 16 16" width="12" height="12" aria-hidden="true">
				<path d="M5 11L11 5M11 5H6M11 5V10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
			</svg>
		</a>
	</header>

	<div class="reviews__container reveal" style="--delay:.3s">
		<ReviewsCarousel reviews={reviews} client:visible />
	</div>
</section>

<style>
	.reviews {
		position: relative;
	}
	.reviews__header {
		width: var(--container-narrow);
		margin: 0 auto clamp(2.5rem, 5vw, 4rem);
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		max-width: 56rem;
	}
	.reviews__lead {
		font-size: clamp(1rem, 0.9vw + 0.6rem, 1.15rem);
		color: #4A453E;
		max-width: 42rem;
		line-height: 1.65;
	}
	.reviews__lead strong {
		color: var(--color-sienne-deep);
		font-weight: 600;
	}
	.reviews__link {
		color: #0A0908;
		border-bottom: 1px solid currentColor;
		transition: color 0.2s;
	}
	.reviews__link:hover {
		color: var(--color-sienne);
	}

	/* Google Reviews CTA — discrete pill with the real Google G logo,
	 * slots under the lead copy, doesn't scream for attention but is
	 * clearly clickable and branded. */
	.reviews__google {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.55rem 0.95rem 0.55rem 0.55rem;
		margin-top: 0.25rem;
		border: 1px solid color-mix(in oklab, #0A0908 14%, transparent);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.65);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		font-family: var(--font-sans);
		font-size: 0.85rem;
		font-weight: 500;
		color: #0A0908;
		width: fit-content;
		transition:
			background 0.3s var(--ease-soft),
			border-color 0.3s var(--ease-soft),
			transform 0.3s var(--ease-emphatic);
	}
	.reviews__google:hover {
		background: #ffffff;
		border-color: #0A0908;
		transform: translateY(-1px);
	}
	.reviews__google-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.6rem;
		height: 1.6rem;
		background: #ffffff;
		border-radius: 999px;
		border: 1px solid color-mix(in oklab, #0A0908 10%, transparent);
	}
	.reviews__google svg:last-child {
		color: color-mix(in oklab, #0A0908 55%, transparent);
		transition: transform 0.3s var(--ease-emphatic);
	}
	.reviews__google:hover svg:last-child {
		transform: translate(2px, -2px);
	}
	.reviews__container {
		width: var(--container);
		margin-inline: auto;
	}

	/* Embla carousel — cream paper style */
	:global(.rev-carousel) {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}
	:global(.rev-carousel__viewport) {
		overflow: hidden;
		padding: 0.75rem 0.5rem;
	}
	:global(.rev-carousel__container) {
		display: flex;
		gap: 1.25rem;
	}
	:global(.rev-carousel__slide) {
		flex: 0 0 100%;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
		padding: 1.75rem;
		border-radius: 1rem;
		background: #FFFFFF;
		border: 1px solid color-mix(in oklab, #0A0908 8%, transparent);
		box-shadow: 0 16px 36px -28px rgba(60, 40, 20, 0.25);
		max-width: 32rem;
		transition:
			transform 0.4s var(--ease-emphatic),
			box-shadow 0.4s var(--ease-emphatic);
	}
	:global(.rev-carousel__slide:hover) {
		transform: translateY(-3px);
		box-shadow: 0 22px 44px -22px rgba(60, 40, 20, 0.32);
	}
	@media (min-width: 768px) {
		:global(.rev-carousel__slide) {
			flex-basis: calc(50% - 0.625rem);
		}
	}
	@media (min-width: 1024px) {
		:global(.rev-carousel__slide) {
			flex-basis: calc(33.333% - 0.83rem);
		}
	}

	:global(.rev-carousel__stars) {
		display: inline-flex;
		gap: 2px;
		color: var(--color-ocre);
	}
	:global(.rev-carousel__stars svg[data-active="false"]) {
		opacity: 0.2;
	}
	:global(.rev-carousel__quote) {
		font-family: var(--font-display);
		font-size: clamp(1.05rem, 0.6vw + 0.8rem, 1.18rem);
		line-height: 1.55;
		color: #0A0908;
		font-style: italic;
		font-variation-settings: "opsz" 144, "SOFT" 50;
		flex: 1;
		font-weight: 400;
	}
	:global(.rev-carousel__cite) {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		font-size: 0.85rem;
	}
	:global(.rev-carousel__cite strong) {
		color: #0A0908;
		font-weight: 500;
	}
	:global(.rev-carousel__cite span) {
		color: #6B6258;
		font-size: 0.75rem;
	}

	:global(.rev-carousel__controls) {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding-inline: 0.5rem;
	}
	:global(.rev-carousel__dots) {
		display: flex;
		gap: 0.4rem;
	}
	:global(.rev-carousel__dot) {
		width: 8px;
		height: 8px;
		border-radius: 999px;
		background: #B8AE9E;
		border: 0;
		padding: 0;
		cursor: pointer;
		transition: all 0.3s var(--ease-emphatic);
	}
	:global(.rev-carousel__dot.is-active) {
		background: #0A0908;
		width: 24px;
	}
	:global(.rev-carousel__buttons) {
		display: flex;
		gap: 0.5rem;
	}
	:global(.rev-carousel__btn) {
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 999px;
		border: 1px solid color-mix(in oklab, #0A0908 18%, transparent);
		background: transparent;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: #0A0908;
		cursor: pointer;
		transition: all 0.3s var(--ease-emphatic);
	}
	:global(.rev-carousel__btn:hover) {
		background: #0A0908;
		color: #F2EEE5;
		border-color: #0A0908;
	}

	.reveal {
		transition-delay: var(--delay, 0s);
	}
</style>
