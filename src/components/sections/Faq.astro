---
import { faqs } from "../../lib/site";
---

<section id="faq" class="faq section-cream section-pad" data-section-mood="cream" aria-labelledby="faq-title">
	<header class="faq__header">
		<p class="eyebrow reveal">Questions fréquentes</p>
		<h2 id="faq-title" class="h-2 reveal balance" style="--delay:.1s">
			Ce que les clients
			<span class="mark-gradient">nous demandent</span>
			le plus.
		</h2>
	</header>

	<div class="faq__list">
		{faqs.map((f, i) => (
			<details class="faq-item reveal" style={`--delay:${0.05 * i + 0.15}s`}>
				<summary>
					<span>{f.q}</span>
					<svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
						<path d="M2 8h12M8 2v12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
					</svg>
				</summary>
				<p>{f.a}</p>
			</details>
		))}
	</div>
</section>

<style>
	.faq {
		position: relative;
	}
	.faq__header {
		width: var(--container-narrow);
		margin: 0 auto clamp(2rem, 4vw, 3rem);
		display: flex;
		flex-direction: column;
		gap: 1rem;
		max-width: 50rem;
	}
	.faq__list {
		width: var(--container-narrow);
		margin-inline: auto;
		display: flex;
		flex-direction: column;
	}
	.faq-item {
		border-top: 1px solid color-mix(in oklab, #0A0908 12%, transparent);
		padding: 1.5rem 0;
	}
	.faq-item:last-child {
		border-bottom: 1px solid color-mix(in oklab, #0A0908 12%, transparent);
	}
	.faq-item summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		cursor: pointer;
		font-family: var(--font-display);
		font-size: clamp(1.05rem, 0.8vw + 0.5rem, 1.35rem);
		font-variation-settings: "opsz" 144, "SOFT" 30;
		line-height: 1.3;
		color: #0A0908;
		list-style: none;
		font-weight: 400;
	}
	.faq-item summary::-webkit-details-marker {
		display: none;
	}
	.faq-item summary svg {
		transition: transform 0.4s var(--ease-emphatic);
		flex-shrink: 0;
		color: var(--color-sienne);
	}
	.faq-item[open] summary svg {
		transform: rotate(45deg);
	}
	.faq-item p {
		padding-top: 0.75rem;
		color: #4A453E;
		font-size: 0.95rem;
		line-height: 1.7;
		max-width: 50rem;
	}
	.reveal {
		transition-delay: var(--delay, 0s);
	}
</style>
