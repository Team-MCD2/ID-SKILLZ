---
import { faqs } from "../../lib/site";
---

<section
	id="faq"
	class="faq section-warm-dark"
	data-section-mood="warm-dark"
	aria-labelledby="faq-title"
>
	<header class="faq__header section-pad-top">
		<p class="eyebrow reveal"><span class="eyebrow-prefix">///</span> INFO_TERMINAL</p>
		<h2 id="faq-title" class="h-2 reveal balance" style="--delay:.1s">
			Ce que les clients
			<span class="mark-gradient">nous demandent</span>
			le plus.
		</h2>
	</header>

	<div class="faq__list">
		{faqs.map((f, i) => (
			<details class="faq-item reveal corner-brackets" style={`--delay:${0.05 * i + 0.15}s`}>
				<summary>
					<span class="faq-item__meta">[ Q_0{i + 1} ]</span>
					<span class="faq-item__q">{f.q}</span>
					<span class="faq-item__icon" aria-hidden="true">
						<svg viewBox="0 0 16 16" width="14" height="14">
							<path d="M2 8h12M8 2v12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
						</svg>
					</span>
				</summary>
				<div class="faq-item__a">
					<p>{f.a}</p>
				</div>
			</details>
		))}
	</div>
</section>

<style>
	.faq {
		position: relative;
		background: #080808;
		padding-bottom: 8rem;
	}
	.faq__header {
		width: var(--container);
		margin-inline: auto;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding-bottom: 4rem;
	}
	.faq__list {
		width: var(--container);
		margin-inline: auto;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.faq-item {
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border);
		transition: all 0.4s var(--ease-soft);
	}
	.faq-item:hover,
	.faq-item[open] {
		background: rgba(255, 255, 255, 0.05);
		border-color: var(--tech);
	}
	.faq-item summary {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		padding: 1.5rem;
		cursor: pointer;
		list-style: none;
	}
	.faq-item summary::-webkit-details-marker { display: none; }
	
	.faq-item__meta {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		color: var(--tech);
		opacity: 0.6;
	}
	.faq-item__q {
		flex: 1;
		font-family: var(--font-mono);
		font-size: 0.95rem;
		color: #fff;
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}
	.faq-item__icon {
		color: var(--tech);
		transition: transform 0.4s var(--ease-emphatic);
	}
	.faq-item[open] .faq-item__icon {
		transform: rotate(45deg);
	}
	.faq-item__a {
		padding: 0 1.5rem 1.5rem 4rem;
	}
	.faq-item__a p {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		line-height: 1.6;
		color: var(--text-muted);
		max-width: 42rem;
	}
</style>
