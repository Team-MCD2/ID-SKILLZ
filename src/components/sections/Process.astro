---
/**
 * Process — section "méthode 6 étapes" mood "warm-dark".
 *
 * Two-column 40/60 sticky split à la Websenso:
 *   - Left  (sticky): eyebrow + title + lead + dual CTA, stays fixed while
 *     the right column scrolls past it.
 *   - Right (scroll): six step cards stacked vertically, each with a giant
 *     watermark step number on the left, a duration pill, a small
 *     geometric glyph, the title and the body copy.
 *
 * Anchor: #methode
 */
import { process } from "../../lib/site";

// Per-step metadata: durations and abstract icons (kept here so it stays
// adjacent to the visual spec). Durations come from FAQ + service estimates.
const stepMeta: Array<{ duration: string; icon: "brief" | "doc" | "compass" | "wrench" | "ship" | "loop" }> = [
	{ duration: "30 min · gratuit", icon: "brief" },
	{ duration: "48 à 72 h", icon: "doc" },
	{ duration: "1 à 3 semaines", icon: "compass" },
	{ duration: "2 à 6 semaines", icon: "wrench" },
	{ duration: "1 semaine", icon: "ship" },
	{ duration: "Long terme", icon: "loop" },
];
---

<section
	id="methode"
	class="proc section-warm-dark section-pad"
	data-section-mood="warm-dark"
	aria-labelledby="proc-title"
>
	<div class="proc__inner">
		<aside class="proc__sticky">
			<p class="eyebrow reveal">Notre méthode</p>
			<h2 id="proc-title" class="h-1 reveal balance" style="--delay:.1s">
				Six étapes,
				<span class="mark-gradient">aucun mystère</span>.
			</h2>
			<p class="proc__lead reveal" style="--delay:.2s">
				Le même process pour tous nos métiers — une trame éprouvée,
				adaptée à chaque projet. Vous savez où en est votre dossier à
				tout moment, vous gardez la main à chaque livrable.
			</p>
			<div class="proc__cta reveal" style="--delay:.3s">
				<a class="proc__btn proc__btn--primary" href="#contact">
					<span>Démarrer le brief</span>
					<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M5 12h14M13 5l7 7-7 7" />
					</svg>
				</a>
				<a class="proc__btn proc__btn--ghost" href="#faq">
					<span>Voir la FAQ</span>
				</a>
			</div>
		</aside>

		<ol class="proc__steps">
			{process.map((step, i) => {
				const meta = stepMeta[i];
				return (
					<li class="proc-step reveal" style={`--delay:${0.05 * i}s`}>
						<span class="proc-step__num watermark-number" aria-hidden="true">{step.index}</span>
						<div class="proc-step__head">
							<span class="tag-pill proc-step__pill">
								<svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<circle cx="12" cy="12" r="9" />
									<path d="M12 7v5l3 2" />
								</svg>
								<span>{meta.duration}</span>
							</span>
							<svg
								class="proc-step__glyph"
								viewBox="0 0 48 48"
								fill="none"
								stroke="currentColor"
								stroke-width="1.4"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								{meta.icon === "brief" && (
									<>
										<rect x="9" y="11" width="30" height="26" rx="2" />
										<path d="M14 19h20M14 26h14M14 33h10" />
									</>
								)}
								{meta.icon === "doc" && (
									<>
										<path d="M12 8h18l6 6v26H12z" />
										<path d="M30 8v6h6M16 22h16M16 28h16M16 34h10" />
									</>
								)}
								{meta.icon === "compass" && (
									<>
										<circle cx="24" cy="24" r="14" />
										<path d="M30 18l-4 8-8 4 4-8 8-4z" fill="currentColor" stroke="none" />
									</>
								)}
								{meta.icon === "wrench" && (
									<>
										<path d="M14 34l14-14M28 14a6 6 0 0 1 6 6 6 6 0 0 1-1.6 4l4 4-3 3-4-4a6 6 0 0 1-4 1.6 6 6 0 0 1-6-6 6 6 0 0 1 1.6-4l-4-4 3-3 4 4A6 6 0 0 1 28 14z" />
									</>
								)}
								{meta.icon === "ship" && (
									<>
										<path d="M8 30h32l-4 8H12z" />
										<path d="M12 30V14l12-4 12 4v16" />
										<path d="M24 10v20" />
									</>
								)}
								{meta.icon === "loop" && (
									<>
										<path d="M14 24a10 10 0 0 1 18-6" />
										<path d="M34 24a10 10 0 0 1-18 6" />
										<path d="M28 12l4 6h-6M20 36l-4-6h6" />
									</>
								)}
							</svg>
						</div>
						<h3 class="proc-step__title">{step.title}</h3>
						<p class="proc-step__text">{step.body}</p>
					</li>
				);
			})}
		</ol>
	</div>
</section>

<style>
	.proc {
		position: relative;
		isolation: isolate;
		overflow: hidden;
	}
	.proc__inner {
		width: var(--container);
		margin-inline: auto;
		display: grid;
		gap: clamp(2.5rem, 5vw, 5rem);
		grid-template-columns: 1fr;
	}
	@media (min-width: 1024px) {
		.proc__inner {
			grid-template-columns: minmax(18rem, 22rem) minmax(0, 1fr);
			gap: clamp(3rem, 6vw, 6rem);
			align-items: start;
		}
	}

	.proc__sticky {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	@media (min-width: 1024px) {
		.proc__sticky {
			position: sticky;
			top: clamp(5rem, 12vh, 8rem);
			align-self: start;
		}
	}

	.proc__lead {
		font-size: clamp(1rem, 0.9vw + 0.6rem, 1.1rem);
		color: var(--text-muted);
		line-height: 1.65;
		max-width: 22rem;
	}

	.proc__cta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 0.5rem;
	}
	.proc__btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.85rem 1.4rem;
		border-radius: 999px;
		font-family: var(--font-sans);
		font-size: 0.85rem;
		font-weight: 500;
		letter-spacing: 0.02em;
		transition:
			background 0.3s var(--ease-soft),
			color 0.3s var(--ease-soft),
			border-color 0.3s var(--ease-soft),
			transform 0.3s var(--ease-emphatic);
	}
	.proc__btn--primary {
		background: var(--color-sienne);
		color: #0A0908;
	}
	.proc__btn--primary:hover {
		background: var(--color-sienne-deep);
		transform: translateY(-2px);
	}
	.proc__btn--ghost {
		border: 1px solid var(--border-strong);
		color: var(--text);
	}
	.proc__btn--ghost:hover {
		border-color: var(--text);
		background: var(--text);
		color: var(--bg);
	}

	/* ----- Right column: stacked steps ---------------------------- */
	.proc__steps {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: clamp(2rem, 4vw, 3.5rem);
	}

	.proc-step {
		position: relative;
		display: grid;
		grid-template-columns: minmax(3.5rem, auto) minmax(0, 1fr);
		gap: 0.75rem 1.5rem;
		padding-block: clamp(1.25rem, 2vw, 1.75rem);
		border-top: 1px solid var(--border);
	}
	.proc-step:last-child {
		border-bottom: 1px solid var(--border);
	}
	.proc-step__num {
		grid-row: 1 / span 3;
		align-self: start;
		padding-top: 0.1rem;
		color: var(--text);
	}
	.proc-step__head {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.proc-step__pill {
		--local-accent: var(--color-ocre);
	}
	.proc-step__pill svg {
		flex-shrink: 0;
	}
	.proc-step__glyph {
		width: 2.25rem;
		height: 2.25rem;
		color: color-mix(in oklab, var(--color-sienne-soft) 80%, transparent);
		flex-shrink: 0;
	}
	.proc-step__title {
		font-family: var(--font-display);
		font-size: clamp(1.4rem, 1.8vw + 0.4rem, 2rem);
		font-weight: 400;
		line-height: 1.1;
		color: var(--text);
		font-variation-settings: "opsz" 144, "SOFT" 30;
		letter-spacing: -0.01em;
	}
	.proc-step__text {
		font-size: clamp(0.95rem, 0.7vw + 0.5rem, 1.05rem);
		color: var(--text-muted);
		line-height: 1.65;
		max-width: 38rem;
	}

	@media (min-width: 1024px) {
		.proc-step {
			grid-template-columns: 5rem minmax(0, 1fr);
			gap: 1rem 2rem;
		}
	}

	.reveal {
		transition-delay: var(--delay, 0s);
	}
</style>
