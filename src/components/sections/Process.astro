---
/**
 * Process — section "méthode 6 étapes" mood "warm-dark".
 *
 * Two-column 40/60 sticky split à la Websenso:
 *   - Left  (sticky): eyebrow + title + lead + dual CTA, stays fixed while
 *     the right column scrolls past it.
 *   - Right (scroll): six step cards stacked vertically, each with a giant
 *     watermark step number on the left, a duration pill, a small
 *     geometric glyph, the title and the body copy.
 *
 * Anchor: #methode
 */
import { process } from "../../lib/site";

// Per-step metadata: durations and abstract icons (kept here so it stays
// adjacent to the visual spec). Durations come from FAQ + service estimates.
const stepMeta: Array<{ duration: string; icon: "brief" | "doc" | "compass" | "wrench" | "ship" | "loop" }> = [
	{ duration: "30 min · gratuit", icon: "brief" },
	{ duration: "48 à 72 h", icon: "doc" },
	{ duration: "1 à 3 semaines", icon: "compass" },
	{ duration: "2 à 6 semaines", icon: "wrench" },
	{ duration: "1 semaine", icon: "ship" },
	{ duration: "Long terme", icon: "loop" },
];
---

<section
	id="methode"
	class="proc section-warm-dark"
	data-section-mood="warm-dark"
	aria-labelledby="proc-title"
>
	<div class="proc__inner">
		<aside class="proc__sticky">
			<p class="eyebrow reveal"><span class="eyebrow-prefix">///</span> EXECUTION_PROTOCOL</p>
			<h2 id="proc-title" class="h-1 reveal balance" style="--delay:.1s">
				Six étapes,
				<span class="mark-gradient">aucun mystère</span>.
			</h2>
			<p class="proc__lead reveal" style="--delay:.2s">
				Une trame éprouvée, pilotée par des spécialistes. Transparence totale,
				maîtrise absolue du flux de production.
			</p>
			<div class="proc__cta reveal" style="--delay:.3s">
				<a class="btn-hud" href="#contact">
					INITIATE_BRIEF
				</a>
				<a class="btn-hud secondary" href="#faq">
					READ_FAQ
				</a>
			</div>
		</aside>

		<ol class="proc__steps">
			{process.map((step, i) => {
				const meta = stepMeta[i];
				return (
					<li class="proc-step reveal corner-brackets" style={`--delay:${0.05 * i}s`}>
						<div class="proc-step__meta">
							<span class="step-id">[ PROTOCOL_0{step.index} ]</span>
							<span class="step-uid">0x{step.index}F2{i}</span>
						</div>
						
						<div class="proc-step__content">
							<div class="proc-step__head">
								<h3 class="proc-step__title">{step.title}</h3>
								<div class="proc-step__tag">
									<span>EST_DURATION: {meta.duration.toUpperCase()}</span>
								</div>
							</div>
							<p class="proc-step__text">{step.body}</p>
						</div>
					</li>
				);
			})}
		</ol>
	</div>
</section>

<style>
	.proc {
		position: relative;
		background: #080808;
		padding-block: 8rem;
	}
	.proc__inner {
		width: var(--container);
		margin-inline: auto;
		display: grid;
		gap: 5rem;
		grid-template-columns: 1fr;
	}
	@media (min-width: 1024px) {
		.proc__inner {
			grid-template-columns: 1fr 1.5fr;
			align-items: start;
		}
	}

	.proc__sticky {
		position: sticky;
		top: 8rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.proc__lead {
		font-family: var(--font-mono);
		font-size: 0.9rem;
		color: var(--text-muted);
		line-height: 1.6;
		max-width: 28rem;
	}

	.proc__cta {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}

	.proc__steps {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.proc-step {
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border);
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		transition: all 0.4s var(--ease-soft);
	}
	.proc-step:hover {
		background: rgba(255, 255, 255, 0.05);
		border-color: var(--tech);
	}

	.proc-step__meta {
		display: flex;
		justify-content: space-between;
		font-family: var(--font-mono);
		font-size: 0.6rem;
		color: var(--tech);
		opacity: 0.8;
	}

	.proc-step__content {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.proc-step__head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 2rem;
		flex-wrap: wrap;
	}

	.proc-step__title {
		font-size: 1.5rem;
		font-weight: 700;
		color: #fff;
	}

	.proc-step__tag {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		color: var(--tech);
		padding: 0.25rem 0.6rem;
		border: 1px solid var(--tech);
		background: rgba(0, 0, 0, 0.4);
	}

	.proc-step__text {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--text-muted);
		line-height: 1.6;
		max-width: 36rem;
	}

	@media (max-width: 640px) {
		.proc-step__head {
			flex-direction: column;
			gap: 0.75rem;
		}
	}
</style>
