---
/**
 * Studio — section "scrolljack 3 images" mood "warm-dark".
 *
 * Pinned-feel section that stays in viewport for ~3 viewport heights of
 * scroll. Three hard-cut images progressively reveal at the 0% / 33% /
 * 66% breakpoints, growing in scale (medium → large → fullwidth) while a
 * sticky text panel on the left updates its heading.
 *
 * The Websenso original showcases the team this way; ID Skillz doesn't
 * have team portraits handy so we reframe as "Le studio" — three facets
 * of the work (archi-viz, marques, terrain) lifted from the renders pool.
 *
 * Anchor: #studio
 */
import TeamScroll from "../islands/TeamScroll";

const slides = [
	{
		src: "/media/renders/render-immeuble-angle-vue-haute.jpg",
		alt: "Vue 3D d'un immeuble en angle haute, perspective architecturale",
		caption:
			"On commence par regarder le terrain — littéralement. Modélisation, perspectives, vues d'angle: la 3D pour aider à se projeter avant la première brique.",
	},
	{
		src: "/media/renders/render-maison-du-pain.jpg",
		alt: "Vue 3D d'une boulangerie avec enseigne 'La Maison du Pain'",
		caption:
			"Puis on habille la marque. Identité, façade, signalétique, packaging — le même studio fabrique ce qu'on imprime, ce qu'on tourne et ce qu'on code.",
	},
	{
		src: "/media/renders/render-immeuble-terrasse-cafe.jpg",
		alt: "Vue 3D d'un immeuble avec terrasse de café au pied",
		caption:
			"Et on filme le terrain. Drone, captations événementielles, motion design — sept ans à courir derrière des marques de sport et des programmes immobiliers.",
	},
];

const headings = [
	"On commence par regarder le terrain.",
	"Puis on habille la marque.",
	"Et on filme le terrain.",
];
---

<section
	id="studio"
	class="studio section-warm-dark"
	data-section-mood="warm-dark"
	aria-labelledby="studio-title"
>
	<h2 id="studio-title" class="visually-hidden">Le studio ID Skillz en trois moments</h2>
	<TeamScroll slides={slides} headings={headings} client:visible />
</section>

<style>
	.studio {
		position: relative;
		background: #080808;
	}

	:global(.teamscroll) {
		position: relative;
		height: 300vh;
	}
	:global(.teamscroll__inner) {
		position: sticky;
		top: 0;
		height: 100vh;
		overflow: hidden;
		display: grid;
		grid-template-columns: 1fr;
		align-items: center;
	}
	@media (min-width: 1024px) {
		:global(.teamscroll__inner) {
			grid-template-columns: 1fr 1.2fr;
			gap: 4rem;
			padding-inline: clamp(4rem, 10vw, 15vw);
		}
	}

	:global(.teamscroll__text) {
		position: relative;
		z-index: 10;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	:global(.teamscroll__meta) {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: var(--font-mono);
		font-size: 0.65rem;
		color: var(--tech);
	}

	:global(.teamscroll__heading) {
		max-width: 12ch;
	}

	:global(.teamscroll__caption) {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--text-muted);
		line-height: 1.6;
		max-width: 28rem;
	}

	:global(.teamscroll__steps) {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}
	:global(.teamscroll__step) {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--text-soft);
		transition: all 0.3s var(--ease-soft);
	}
	:global(.teamscroll__step.is-active) {
		color: var(--tech);
		text-shadow: 0 0 8px var(--tech);
	}

	:global(.teamscroll__stage) {
		position: relative;
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	:global(.teamscroll__slide) {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transform: scale(var(--scale, 0.75));
		transition: all 0.8s var(--ease-emphatic);
	}
	:global(.teamscroll__slide.is-active) {
		opacity: 1;
	}

	:global(.teamscroll__frame) {
		position: relative;
		width: 100%;
		height: 100%;
		max-width: 90%;
		max-height: 80vh;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		border: 1px solid var(--border);
	}

	:global(.teamscroll__slide img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.6;
		filter: grayscale(1);
		transition: all 1s var(--ease-soft);
	}
	:global(.teamscroll__slide.is-active img) {
		opacity: 0.8;
		filter: grayscale(0.5);
	}

	:global(.teamscroll__overlay) {
		position: absolute;
		bottom: 1.5rem;
		left: 1.5rem;
		display: flex;
		gap: 1rem;
	}
	:global(.teamscroll__overlay .tag) {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		padding: 0.25rem 0.6rem;
		background: rgba(0, 0, 0, 0.6);
		color: var(--tech);
		border: 1px solid var(--tech);
	}

	@media (max-width: 1023px) {
		:global(.teamscroll__inner) {
			padding: 2rem;
			padding-top: var(--header-height);
		}
		:global(.teamscroll__stage) {
			position: absolute;
			inset: 0;
			z-index: -1;
		}
		:global(.teamscroll__slide img) {
			width: 100vw;
			height: 100vh;
			opacity: 0.3 !important;
		}
		:global(.teamscroll__frame) {
			max-width: 100%;
			max-height: 100%;
			border: none;
		}
	}

	.visually-hidden {
		position: absolute !important;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
