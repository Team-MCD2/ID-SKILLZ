---
/**
 * Studio — section "scrolljack 3 images" mood "warm-dark".
 *
 * Pinned-feel section that stays in viewport for ~3 viewport heights of
 * scroll. Three hard-cut images progressively reveal at the 0% / 33% /
 * 66% breakpoints, growing in scale (medium → large → fullwidth) while a
 * sticky text panel on the left updates its heading.
 *
 * The Websenso original showcases the team this way; ID Skillz doesn't
 * have team portraits handy so we reframe as "Le studio" — three facets
 * of the work (archi-viz, marques, terrain) lifted from the renders pool.
 *
 * Anchor: #studio
 */
import TeamScroll from "../islands/TeamScroll";

const slides = [
	{
		src: "/media/renders/render-immeuble-angle-vue-haute.jpg",
		alt: "Vue 3D d'un immeuble en angle haute, perspective architecturale",
		caption:
			"On commence par regarder le terrain — littéralement. Modélisation, perspectives, vues d'angle: la 3D pour aider à se projeter avant la première brique.",
	},
	{
		src: "/media/renders/render-maison-du-pain.jpg",
		alt: "Vue 3D d'une boulangerie avec enseigne 'La Maison du Pain'",
		caption:
			"Puis on habille la marque. Identité, façade, signalétique, packaging — le même studio fabrique ce qu'on imprime, ce qu'on tourne et ce qu'on code.",
	},
	{
		src: "/media/renders/render-immeuble-terrasse-cafe.jpg",
		alt: "Vue 3D d'un immeuble avec terrasse de café au pied",
		caption:
			"Et on filme le terrain. Drone, captations événementielles, motion design — sept ans à courir derrière des marques de sport et des programmes immobiliers.",
	},
];

const headings = [
	"On commence par regarder le terrain.",
	"Puis on habille la marque.",
	"Et on filme le terrain.",
];
---

<section
	id="studio"
	class="studio section-warm-dark"
	data-section-mood="warm-dark"
	aria-labelledby="studio-title"
>
	<h2 id="studio-title" class="visually-hidden">Le studio ID Skillz en trois moments</h2>
	<TeamScroll slides={slides} headings={headings} client:visible />
</section>

<style>
	.studio {
		position: relative;
	}

	:global(.teamscroll) {
		position: relative;
		height: 300vh;
	}
	:global(.teamscroll__inner) {
		position: sticky;
		top: 0;
		height: 100vh;
		overflow: hidden;
		display: grid;
		grid-template-columns: 1fr;
		/* Default (mobile-first): pin the text to the top of the sticky
		 * panel so the headline sits close to the nav bar when the
		 * section locks. Desktop overrides below re-centers the compo. */
		align-items: flex-start;
	}
	@media (min-width: 1024px) {
		:global(.teamscroll__inner) {
			grid-template-columns: minmax(20rem, 32rem) minmax(0, 1fr);
			gap: clamp(2rem, 5vw, 5rem);
			padding-inline: clamp(1.5rem, 4vw, 4rem);
		}
	}

	:global(.teamscroll__text) {
		position: relative;
		z-index: 3;
		padding: clamp(1.5rem, 4vw, 3rem);
		padding-top: calc(var(--header-height) + 1.25rem);
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	@media (min-width: 1024px) {
		:global(.teamscroll__inner) {
			/* Desktop keeps the vertical centered composition so the left
			 * editorial column floats in the middle next to the image. */
			align-items: center;
		}
		:global(.teamscroll__text) {
			padding-top: clamp(1.5rem, 4vw, 3rem);
		}
	}

	@media (max-width: 1023px) {
		:global(.teamscroll__text) {
			/* Remove the fade-gradient behind the text: it bleeds onto the
			 * edges of the image and looks like a dirty halo (Image 1 & 7
			 * from the feedback pass). We now rely on a single global veil
			 * painted on the image itself (see .teamscroll__slide img filter
			 * below) to keep the text legible against any image. */
			background: none;
			max-width: 38rem;
		}
		/* Stale rule kept as a no-op so the linear-gradient block below
		 * (which was the visual offender) stops painting. */
		:global(.teamscroll__text).legacy-gradient {
			background: linear-gradient(
				180deg,
				color-mix(in oklab, var(--bg) 92%, transparent) 0%,
				color-mix(in oklab, var(--bg) 0%, transparent) 100%
			);
		}
	}

	:global(.teamscroll__heading) {
		min-height: 3em;
		transition: opacity 0.5s var(--ease-emphatic);
	}

	:global(.teamscroll__caption) {
		font-size: clamp(0.95rem, 0.7vw + 0.5rem, 1.05rem);
		color: var(--text-muted);
		line-height: 1.65;
		max-width: 28rem;
		min-height: 5em;
	}

	:global(.teamscroll__steps) {
		display: flex;
		gap: 0.5rem;
		margin-top: 0.5rem;
	}
	:global(.teamscroll__step) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.4rem;
		height: 2.4rem;
		border-radius: 999px;
		background: transparent;
		border: 1px solid var(--border);
		color: var(--text-soft);
		font-family: var(--font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.06em;
		cursor: pointer;
		transition:
			background 0.3s var(--ease-soft),
			color 0.3s var(--ease-soft),
			border-color 0.3s var(--ease-soft);
	}
	:global(.teamscroll__step.is-active) {
		background: var(--color-sienne);
		border-color: var(--color-sienne);
		color: #0A0908;
	}

	:global(.teamscroll__stage) {
		position: relative;
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	@media (max-width: 1023px) {
		:global(.teamscroll__stage) {
			position: absolute;
			inset: 0;
			z-index: 1;
		}
	}

	:global(.teamscroll__slide) {
		position: absolute;
		inset: 0;
		margin: auto;
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transform: scale(var(--scale, 0.7));
		transition:
			opacity 0.6s var(--ease-emphatic),
			transform 0.8s var(--ease-emphatic);
	}
	:global(.teamscroll__slide.is-active) {
		opacity: 1;
	}
	:global(.teamscroll__slide img) {
		width: 100%;
		height: 100%;
		max-width: min(60rem, 90%);
		max-height: 80vh;
		object-fit: cover;
		border-radius: 1rem;
		box-shadow: 0 30px 60px -30px rgba(0, 0, 0, 0.55);
	}
	:global(.teamscroll__slide:nth-child(3) img) {
		max-width: 100%;
		max-height: 90vh;
		border-radius: 0.5rem;
	}

	@media (max-width: 1023px) {
		:global(.teamscroll__slide img) {
			max-width: 100%;
			max-height: 100vh;
			width: 100vw;
			height: 100vh;
			border-radius: 0;
			object-fit: cover;
			/* Darker filter than before so the headline above never
			 * fights the render's bright windows / sky for contrast. */
			filter: brightness(0.42) saturate(1.05);
		}
		/* Full-bleed linear veil painted as a pseudo over the slide so
		 * the text header at the top of the viewport always has a dark
		 * wash beneath it. Stronger at the top, fades by the bottom 40%. */
		:global(.teamscroll__slide.is-active)::after {
			content: "";
			position: absolute;
			inset: 0;
			background: linear-gradient(
				180deg,
				rgba(10, 9, 8, 0.85) 0%,
				rgba(10, 9, 8, 0.55) 35%,
				rgba(10, 9, 8, 0.35) 60%,
				rgba(10, 9, 8, 0.75) 100%
			);
			pointer-events: none;
			z-index: 2;
		}
	}

	.visually-hidden {
		position: absolute !important;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
