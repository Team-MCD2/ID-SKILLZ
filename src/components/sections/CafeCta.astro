---
/**
 * CafeCta — closing card "Un café?" mood "warm-dark" with a sienne fill.
 *
 * Centerpiece is the massive vertical typography spelling UN/CA/FÉ? — one
 * row per syllable, all-caps, hand-cut serif italic for the "?" — and a
 * date-grabbing CTA button on the right. Inspired directly by the
 * Websenso closing card; reskinned in ID Skillz tones.
 *
 * Anchor: #cafe
 */
import { site } from "../../lib/site";

const lines = ["UN", "CA", "FÉ?"];
---

<section
	id="cafe"
	class="cafe section-warm-dark"
	data-section-mood="warm-dark"
	aria-labelledby="cafe-title"
>
	<div class="cafe__card corner-brackets">
		<div class="cafe__meta">
			<span class="meta-id">[ ACCESS_TERMINAL ]</span>
			<span class="meta-auth">AUTH_CODE: 0xCAF3</span>
		</div>

		<div class="cafe__content">
			<h2 id="cafe-title" class="cafe__title">
				{lines.map((l, i) => (
					<span class="cafe__line" style={`--i:${i}`}>
						<span class="cafe__line-inner">{l}</span>
					</span>
				))}
			</h2>

			<aside class="cafe__aside reveal">
				<p class="cafe__eyebrow"><span class="eyebrow-prefix">///</span> CONNECTION_ESTABLISHED</p>
				<p class="cafe__lead">
					Trente minutes pour parler de votre projet, sans engagement.
					Canal sécurisé : café, visio, ou téléphone.
				</p>
				<div class="cafe__actions">
					<a class="btn-hud" href={`tel:${site.phone.replace(/\s+/g, "")}`}>
						VOICE_LINK: {site.phone}
					</a>
					<a class="btn-hud secondary" href="#contact">
						RESERVE_SLOT
					</a>
				</div>
				<p class="cafe__small">
					LOC: COLOMIERS_31 // HQ: PARIS_08 // RESPONSE_EST: 48H
				</p>
			</aside>
		</div>
	</div>
</section>

<style>
	.cafe {
		position: relative;
		background: #080808;
		padding-bottom: 8rem;
	}

	.cafe__card {
		width: var(--container);
		margin-inline: auto;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border);
		padding: 4rem;
		display: flex;
		flex-direction: column;
		gap: 4rem;
	}

	.cafe__meta {
		display: flex;
		justify-content: space-between;
		font-family: var(--font-mono);
		font-size: 0.65rem;
		color: var(--tech);
		opacity: 0.8;
	}

	.cafe__content {
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (min-width: 1024px) {
		.cafe__content {
			grid-template-columns: 1.2fr 1fr;
		}
	}

	.cafe__title {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: clamp(4rem, 12vw, 10rem);
		line-height: 0.85;
		color: #fff;
		margin: 0;
	}
	.cafe__line {
		display: block;
		overflow: hidden;
	}
	.cafe__line-inner {
		display: inline-block;
		transform: translateY(100%);
		animation: cafe-rise 0.8s var(--ease-emphatic) calc(var(--i) * 0.1s + 0.2s) forwards;
	}
	@keyframes cafe-rise {
		to { transform: translateY(0); }
	}

	.cafe__aside {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.cafe__eyebrow {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--tech);
	}

	.cafe__lead {
		font-family: var(--font-mono);
		font-size: 1.1rem;
		line-height: 1.6;
		color: var(--text-muted);
		max-width: 28rem;
	}

	.cafe__actions {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.cafe__small {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		color: var(--text-soft);
		opacity: 0.6;
		border-top: 1px solid var(--border);
		padding-top: 1.5rem;
	}

	@media (max-width: 640px) {
		.cafe__card { padding: 2rem; }
		.cafe__title { font-size: 4.5rem; }
	}
</style>
