---
/**
 * CafeCta — closing card "Un café?" mood "warm-dark" with a sienne fill.
 *
 * Centerpiece is the massive vertical typography spelling UN/CA/FÉ? — one
 * row per syllable, all-caps, hand-cut serif italic for the "?" — and a
 * date-grabbing CTA button on the right. Inspired directly by the
 * Websenso closing card; reskinned in ID Skillz tones.
 *
 * Anchor: #cafe
 */
import { site } from "../../lib/site";

const lines = ["UN", "CA", "FÉ?"];
---

<section
	id="cafe"
	class="cafe section-warm-dark section-pad"
	data-section-mood="warm-dark"
	aria-labelledby="cafe-title"
>
	<div class="cafe__card">
		<span class="cafe__corner cafe__corner--tl" aria-hidden="true"></span>
		<span class="cafe__corner cafe__corner--tr" aria-hidden="true"></span>
		<span class="cafe__corner cafe__corner--bl" aria-hidden="true"></span>
		<span class="cafe__corner cafe__corner--br" aria-hidden="true"></span>

		<h2 id="cafe-title" class="cafe__title">
			{lines.map((l, i) => (
				<span class="cafe__line" style={`--i:${i}`}>
					<span class="cafe__line-inner">{l}</span>
				</span>
			))}
		</h2>

		<aside class="cafe__aside reveal">
			<p class="cafe__eyebrow">Un échange, pas un brief</p>
			<p class="cafe__lead">
				Trente minutes pour parler de votre projet, sans engagement.
				Café, visio, ou téléphone — au choix.
			</p>
			<div class="cafe__actions">
				<a
					class="cafe__btn cafe__btn--primary"
					href={`tel:${site.phone.replace(/\s+/g, "")}`}
				>
					<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13 1.05.37 2.07.72 3.06a2 2 0 0 1-.45 2.11L8.09 10.18a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c1 .35 2.01.59 3.06.72A2 2 0 0 1 22 16.92z" />
					</svg>
					<span>Appeler {site.phone}</span>
				</a>
				<a class="cafe__btn cafe__btn--ghost" href="#contact">
					<span>Réserver un créneau</span>
					<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M5 12h14M13 5l7 7-7 7" />
					</svg>
				</a>
			</div>
			<p class="cafe__small">
				Studio à Colomiers (31) — siège social Paris 8&nbsp;⋅&nbsp;Réponse sous 48h
			</p>
		</aside>

		{/* Hand-drawn coffee glyph in the negative space, decorative */}
		<svg
			class="cafe__glyph"
			viewBox="0 0 80 80"
			fill="none"
			stroke="currentColor"
			stroke-width="1.4"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<path d="M14 32h44v18a14 14 0 0 1-14 14H28a14 14 0 0 1-14-14z" />
			<path d="M58 38h6a8 8 0 0 1 0 16h-6" />
			<path d="M24 14c0 4 4 4 4 8s-4 4-4 8" opacity=".75" />
			<path d="M36 14c0 4 4 4 4 8s-4 4-4 8" opacity=".55" />
			<path d="M48 14c0 4 4 4 4 8s-4 4-4 8" opacity=".4" />
		</svg>
	</div>
</section>

<style>
	.cafe {
		position: relative;
	}

	.cafe__card {
		width: var(--container);
		margin-inline: auto;
		position: relative;
		isolation: isolate;
		padding: clamp(2.5rem, 5vw, 4rem) clamp(1.75rem, 4vw, 3.5rem)
			clamp(2.5rem, 5vw, 4rem);
		border-radius: 1.5rem;
		background:
			radial-gradient(
				circle at 18% 110%,
				color-mix(in oklab, var(--color-sienne) 35%, var(--bg)) 0%,
				color-mix(in oklab, var(--color-sienne-deep) 25%, var(--bg)) 35%,
				var(--bg) 80%
			);
		border: 1px solid color-mix(in oklab, var(--color-sienne) 35%, transparent);
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(1.5rem, 3vw, 3rem);
		min-height: 26rem;
		overflow: hidden;
	}
	@media (min-width: 1024px) {
		.cafe__card {
			grid-template-columns: minmax(0, 1.2fr) minmax(20rem, 24rem);
			gap: clamp(2rem, 5vw, 5rem);
			align-items: center;
		}
	}

	.cafe__corner {
		position: absolute;
		width: 1.5rem;
		height: 1.5rem;
		border-color: color-mix(in oklab, var(--color-sienne) 65%, white);
		border-style: solid;
		border-width: 0;
		opacity: 0.55;
	}
	.cafe__corner--tl {
		top: 1rem;
		left: 1rem;
		border-top-width: 1px;
		border-left-width: 1px;
	}
	.cafe__corner--tr {
		top: 1rem;
		right: 1rem;
		border-top-width: 1px;
		border-right-width: 1px;
	}
	.cafe__corner--bl {
		bottom: 1rem;
		left: 1rem;
		border-bottom-width: 1px;
		border-left-width: 1px;
	}
	.cafe__corner--br {
		bottom: 1rem;
		right: 1rem;
		border-bottom-width: 1px;
		border-right-width: 1px;
	}

	.cafe__title {
		font-family: var(--font-display);
		font-weight: 400;
		font-style: italic;
		font-size: clamp(4.5rem, 14vw, 12rem);
		line-height: 0.85;
		letter-spacing: -0.04em;
		color: var(--text);
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
	}
	.cafe__line {
		display: block;
		overflow: hidden;
	}
	.cafe__line-inner {
		display: inline-block;
		background: linear-gradient(
			120deg,
			var(--color-sienne) 0%,
			var(--color-ocre) 60%,
			color-mix(in oklab, var(--color-sable) 80%, white) 100%
		);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		-webkit-text-fill-color: transparent;
		transform: translateY(110%);
		animation: cafe-rise 1s var(--ease-emphatic) calc(var(--i) * 0.12s + 0.2s) forwards;
	}

	@keyframes cafe-rise {
		to {
			transform: translateY(0);
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.cafe__line-inner {
			transform: none;
			animation: none;
		}
	}

	.cafe__aside {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding-bottom: clamp(0.5rem, 2vw, 1.5rem);
		max-width: 22rem;
	}
	.cafe__eyebrow {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-ocre);
	}
	.cafe__lead {
		font-family: var(--font-display);
		font-size: clamp(1.15rem, 1vw + 0.6rem, 1.4rem);
		line-height: 1.4;
		color: var(--text);
		font-weight: 400;
	}
	.cafe__actions {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		margin-top: 0.5rem;
	}
	.cafe__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.55rem;
		padding: 0.95rem 1.4rem;
		border-radius: 999px;
		font-family: var(--font-sans);
		font-size: 0.85rem;
		font-weight: 500;
		letter-spacing: 0.02em;
		transition:
			background 0.3s var(--ease-soft),
			color 0.3s var(--ease-soft),
			border-color 0.3s var(--ease-soft),
			transform 0.3s var(--ease-emphatic);
	}
	.cafe__btn--primary {
		background: var(--color-sienne);
		color: #0A0908;
	}
	.cafe__btn--primary:hover {
		background: var(--color-sienne-deep);
		transform: translateY(-2px);
	}
	.cafe__btn--ghost {
		border: 1px solid color-mix(in oklab, var(--text) 25%, transparent);
		color: var(--text);
	}
	.cafe__btn--ghost:hover {
		border-color: var(--text);
		background: var(--text);
		color: var(--bg);
	}
	.cafe__small {
		font-size: 0.72rem;
		color: var(--text-soft);
		font-family: var(--font-mono);
		letter-spacing: 0.04em;
		margin-top: 0.5rem;
	}

	.cafe__glyph {
		position: absolute;
		right: -3rem;
		top: -3rem;
		width: 14rem;
		height: 14rem;
		color: color-mix(in oklab, var(--color-sienne-soft) 70%, transparent);
		opacity: 0.35;
		pointer-events: none;
	}
	@media (max-width: 720px) {
		.cafe__glyph {
			display: none;
		}
	}

	.reveal {
		transition-delay: var(--delay, 0s);
	}
</style>
