---
/**
 * Hero — section ouverte du site, mood "warm-dark".
 *
 * Structure (Websenso-inspired, ID Skillz palette):
 *   - Background: showreel video, soft grayscale, sienne radial-gradient warmth
 *   - Top-left:   eyebrow + headline with mark-gradient + lead
 *   - Bottom:     CTA pair + horizontal stats divider
 *   - Bottom mask: hand-drawn mountain ridge SVG, fill = next section bg.
 *                  This is the signature transition into the cream "Solutions"
 *                  section that follows.
 *   - Top-right corner: small editorial sketch glyph (signature mark)
 *
 * The section declares `data-section-mood="warm-dark"` so the floating action
 * button (Fab.astro) automatically picks the right surface tokens.
 */
import MountainRidge from "../MountainRidge.astro";
import { site } from "../../lib/site";

const stats = [
	{ value: `Depuis ${site.founded}`, label: "agence créative" },
	{ value: "19", label: "projets livrés" },
	{ value: "10+", label: "marques accompagnées" },
	{ value: "Paris · Toulouse", label: "double studio" },
];
---

<section
	id="hero"
	class="hero section-warm-dark"
	data-section-mood="warm-dark"
	aria-labelledby="hero-title"
>
	<div class="hero__bg" aria-hidden="true">
		<video
			class="hero__video"
			src="/media/videos/NA-DECOUVREZ_NOS_SERVICES_ID_SKILLZ_VOTRE_AGENCE_DE_COMMUNICATION.mp4"
			autoplay
			muted
			loop
			playsinline
			preload="metadata"
			poster="/media/renders/render-immeuble-terrasse-cafe.jpg"
		></video>
		<div class="hero__veil"></div>
	</div>

	<!-- Editorial sketch glyph, top-right -->
	<svg
		class="hero__sketch"
		viewBox="0 0 120 120"
		fill="none"
		stroke="currentColor"
		stroke-width="1.25"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<!-- Star/sparkle — abstract creativity mark -->
		<path d="M60 18 L66 54 L102 60 L66 66 L60 102 L54 66 L18 60 L54 54 Z" />
		<circle cx="60" cy="60" r="3" fill="currentColor" stroke="none" />
		<!-- Hand-sketched bracket -->
		<path d="M14 10 Q 10 10 10 14 L 10 22" />
		<path d="M106 110 Q 110 110 110 106 L 110 98" />
	</svg>

	<div class="hero__inner">
		<p class="eyebrow hero__eyebrow reveal">Studio créatif · Paris · Toulouse</p>

		<h1
			id="hero-title"
			class="hero__title h-display reveal balance"
			style="--delay:.15s"
		>
			On construit
			<span class="mark-gradient">des marques</span>
			qu&rsquo;on n&rsquo;oublie pas.
		</h1>

		<p class="hero__lead reveal" style="--delay:.3s">
			Site internet, identité visuelle, vidéo de marque, modélisation 3D.
			Quatre métiers&nbsp;— une seule signature&nbsp;: <em>Our Skillz, Your ID</em>.
		</p>

		<div class="hero__actions reveal" style="--delay:.45s">
			<a class="btn btn--primary" href="#contact">
				<span>Démarrer un projet</span>
				<svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
					<path d="M2 8h12M9 3l5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</a>
			<a class="btn btn--ghost" href="#realisations">
				<span>Voir le travail</span>
			</a>
		</div>

		<dl class="hero__stats reveal" style="--delay:.6s">
			{stats.map((s, i) => (
				<div class="hero__stat" data-index={i}>
					<dt>{s.value}</dt>
					<dd>{s.label}</dd>
				</div>
			))}
		</dl>
	</div>

	<!-- Mountain ridge transitioning to the cream Solutions section below.
	     Fill explicitly set to the cream surface color so the SVG paints the
	     "valley" we descend into. -->
	<MountainRidge fill="#F2EEE5" variant="ridge" />
</section>

<style>
	.hero {
		position: relative;
		min-height: 100dvh;
		min-height: 100vh;
		display: flex;
		align-items: center;
		padding-block: calc(var(--header-height) + 3rem) clamp(8rem, 14vw, 14rem);
		overflow: hidden;
		isolation: isolate;
	}

	.hero__bg {
		position: absolute;
		inset: 0;
		z-index: -2;
	}
	.hero__video {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: grayscale(0.55) contrast(1.05) brightness(0.9);
	}
	.hero__veil {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(
				ellipse at 18% 25%,
				color-mix(in oklab, var(--color-sienne) 22%, transparent) 0%,
				transparent 55%
			),
			linear-gradient(
				180deg,
				rgba(10, 9, 8, 0.45) 0%,
				rgba(10, 9, 8, 0.55) 35%,
				rgba(10, 9, 8, 0.85) 80%,
				rgba(10, 9, 8, 0.95) 100%
			);
	}

	.hero__sketch {
		position: absolute;
		top: clamp(5.5rem, 8vw, 7.5rem);
		right: clamp(1rem, 4vw, 3rem);
		width: clamp(5rem, 8vw, 7rem);
		height: auto;
		color: color-mix(in oklab, var(--color-ocre) 60%, transparent);
		pointer-events: none;
		opacity: 0.7;
		animation: heroSketchFloat 6s var(--ease-emphatic) infinite alternate;
	}
	@keyframes heroSketchFloat {
		from { transform: translate3d(0, 0, 0) rotate(-2deg); }
		to   { transform: translate3d(-6px, 8px, 0) rotate(3deg); }
	}
	@media (prefers-reduced-motion: reduce) {
		.hero__sketch { animation: none; }
	}

	.hero__inner {
		position: relative;
		width: var(--container);
		margin-inline: auto;
		display: flex;
		flex-direction: column;
		gap: 1.4rem;
		max-width: 64rem;
	}

	.hero__eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}
	.hero__eyebrow::before {
		content: "";
		width: 1.75rem;
		height: 1px;
		background: var(--color-ocre);
	}

	.hero__title {
		max-width: 18ch;
		color: var(--text);
	}
	.hero__title .mark-gradient {
		display: inline-block;
	}

	.hero__lead {
		max-width: 38rem;
		font-size: clamp(1.05rem, 1.4vw + 0.5rem, 1.35rem);
		color: var(--text-muted);
		line-height: 1.55;
		font-weight: 300;
	}
	.hero__lead em {
		font-family: var(--font-display);
		font-style: italic;
		color: var(--text);
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 0.5rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.95rem 1.6rem;
		border-radius: 999px;
		font-size: 0.95rem;
		font-weight: 500;
		letter-spacing: -0.01em;
		transition:
			transform 0.3s var(--ease-emphatic),
			background 0.2s,
			color 0.2s,
			border-color 0.2s;
	}
	.btn--primary {
		background: var(--color-sienne);
		color: var(--bg);
	}
	.btn--primary:hover {
		transform: translateY(-2px);
		background: var(--color-sienne-deep);
	}
	.btn--ghost {
		background: transparent;
		color: var(--text);
		border: 1px solid var(--border-strong);
	}
	.btn--ghost:hover {
		background: var(--text);
		color: var(--bg);
		border-color: var(--text);
	}

	/* ----- Stats divider ------------------------------------------------ */
	.hero__stats {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.5rem 2.5rem;
		margin-top: 2.25rem;
		padding-top: 1.75rem;
		border-top: 1px solid var(--border);
	}
	.hero__stat dt {
		font-family: var(--font-display);
		font-size: clamp(1.15rem, 1.5vw + 0.5rem, 1.65rem);
		font-weight: 500;
		font-variation-settings: "opsz" 144, "SOFT" 20;
		color: var(--text);
		line-height: 1;
		letter-spacing: -0.02em;
	}
	.hero__stat dd {
		margin: 0.4rem 0 0;
		font-size: 0.78rem;
		font-weight: 400;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--text-soft);
	}

	@media (max-width: 768px) {
		.hero__stats {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1.25rem 1.5rem;
		}
	}

	/* ----- Mountain ridge palette swap when on light theme.
	         The MountainRidge component ships with a hardcoded fill so we
	         override via CSS targeting the inserted SVG when theme is light. */
	:root[data-theme="light"] .hero .mountain-ridge svg path,
	@media (prefers-color-scheme: light) {
		:root:not([data-theme]) .hero .mountain-ridge svg path {
			/* Light theme: cream → cream, no visible ridge needed */
			fill: #F2EEE5;
		}
	}

	/* Reveal cascade */
	.reveal {
		transition-delay: var(--delay, 0s);
	}
</style>
