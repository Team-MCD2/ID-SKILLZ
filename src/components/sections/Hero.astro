---
/**
 * Hero — section ouverte du site, mood "warm-dark".
 *
 * Structure (Websenso-inspired, ID Skillz palette):
 *   - Background: showreel video, soft grayscale, sienne radial-gradient warmth
 *   - Top-left:   eyebrow + headline with mark-gradient + lead
 *   - Bottom:     CTA pair + horizontal stats divider
 *   - Bottom mask: hand-drawn mountain ridge SVG, fill = next section bg.
 *                  This is the signature transition into the cream "Solutions"
 *                  section that follows.
 *   - Top-right corner: small editorial sketch glyph (signature mark)
 *
 * The section declares `data-section-mood="warm-dark"` so the floating action
 * button (Fab.astro) automatically picks the right surface tokens.
 */
import MountainRidge from "../MountainRidge.astro";
import { site } from "../../lib/site";

const stats = [
	{ value: `Depuis ${site.founded}`, label: "agence créative" },
	{ value: "19", label: "projets livrés" },
	{ value: "10+", label: "marques accompagnées" },
	{ value: "Paris · Toulouse", label: "double studio" },
];
---

<section
	id="hero"
	class="hero"
	data-section-mood="warm-dark"
	aria-labelledby="hero-title"
>
	<div class="hero__bg" aria-hidden="true">
		<video
			class="hero__video"
			src="/media/videos/NA-DECOUVREZ_NOS_SERVICES_ID_SKILLZ_VOTRE_AGENCE_DE_COMMUNICATION.mp4"
			autoplay
			muted
			loop
			playsinline
			preload="metadata"
			disablePictureInPicture
			disableRemotePlayback
		></video>
		<div class="hero__overlay"></div>
	</div>

	<div class="hero__inner">
		<div class="hero__metadata reveal">
			<span class="eyebrow"><span class="eyebrow-prefix">///</span> AG_CREATIVE_SYSTEM_V2.0</span>
			<span class="eyebrow"><span class="eyebrow-prefix">///</span> LOC: 48.8566_N_2.3522_E</span>
		</div>

		<h1
			id="hero-title"
			class="hero__title h-display reveal"
			style="--delay:.15s"
		>
			Expériences<br />
			<span class="mark-gradient">Numériques</span><span class="hero__cursor">_</span>
		</h1>

		<p class="hero__lead reveal" style="--delay:.3s">
			Nous fusionnons Design de pointe, Stratégie et Tech pour bâtir les fleurons digitaux de demain.
		</p>

		<div class="hero__actions reveal" style="--delay:.45s">
			<a class="btn-hud btn-hud-primary" href="#contact">Initialiser_Projet</a>
			<a class="btn-hud" href="#realisations">Voir_Portfolio</a>
		</div>

		<dl class="hero__stats reveal" style="--delay:.6s">
			{stats.map((s, i) => (
				<div class="hero__stat">
					<dt>{s.value}</dt>
					<dd>{s.label}</dd>
				</div>
			))}
		</dl>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		padding-top: var(--header-height);
		overflow: hidden;
		isolation: isolate;
	}

	.hero__bg {
		position: absolute;
		inset: 0;
		z-index: -2;
	}
	.hero__video {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.15;
		filter: grayscale(1) contrast(1.2);
	}
	.hero__overlay {
		position: absolute;
		inset: 0;
		background: radial-gradient(circle at 50% 50%, transparent 0%, #080808 90%);
	}

	.hero__inner {
		width: var(--container);
		margin-inline: auto;
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
		padding-block: 4rem;
	}

	.hero__metadata {
		display: flex;
		gap: 2rem;
		margin-bottom: -1rem;
	}

	.hero__title {
		max-width: 12ch;
	}

	.hero__cursor {
		color: var(--tech);
		animation: blink 1s step-end infinite;
	}

	@keyframes blink {
		from, to { opacity: 1; }
		50% { opacity: 0; }
	}

	.hero__lead {
		max-width: 32rem;
		font-size: clamp(1.1rem, 1.5vw, 1.4rem);
		color: var(--text-muted);
		line-height: 1.5;
	}

	.hero__actions {
		display: flex;
		gap: 1.5rem;
		margin-top: 1rem;
	}

	.hero__stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
		gap: 2rem;
		margin-top: 4rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
	}

	.hero__stat dt {
		font-family: var(--font-display);
		font-size: 1.25rem;
		font-weight: 700;
		color: #fff;
		margin-bottom: 0.5rem;
	}

	.hero__stat dd {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--tech);
	}

	@media (max-width: 768px) {
		.hero__inner {
			gap: 2rem;
			padding-block: 2rem;
		}
		.hero__metadata {
			flex-direction: column;
			gap: 0.5rem;
		}
		.hero__stats {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
