---
/**
 * Hero — section ouverte du site, mood "warm-dark".
 *
 * Tech Cinématographique HUD treatment:
 *   - Background: Vantablack (#080808) with aubergine radial gradient,
 *     subtle grid overlay, and film grain texture.
 *   - HUD metadata panel top-right (REC_ACTIVE, RES, FPS)
 *   - Corner bracket visors (top-left, bottom-right)
 *   - Title: "CRÉATEURS DE RÉALITÉS NUMÉRIQUES_" with gradient + blink cursor
 *   - Eyebrow: "/// STUDIO DE CRÉATION 3D & LOGICIELLE _"
 *   - Bottom: CTA pair + horizontal stats divider
 *   - Bottom mask: mountain ridge SVG transition into cream Solutions
 *
 * The section declares `data-section-mood="warm-dark"` so the floating action
 * button (Fab.astro) automatically picks the right surface tokens.
 */
import MountainRidge from "../MountainRidge.astro";
import { site } from "../../lib/site";

const stats = [
	{ value: `Depuis ${site.founded}`, label: "agence créative" },
	{ value: "19", label: "projets livrés" },
	{ value: "10+", label: "marques accompagnées" },
	{ value: "Paris · Toulouse", label: "double studio" },
];
---

<section
	id="hero"
	class="hero section-warm-dark"
	data-section-mood="warm-dark"
	aria-labelledby="hero-title"
>
	<!-- HUD Background Stack -->
	<div class="hero__bg" aria-hidden="true">
		<!-- Layer 0: Vantablack base -->
		<div class="hero__base"></div>
		<!-- Layer 1: Simulation de la vidéo ID Skills en fond -->
		<div class="hero__image-sim"></div>
		<!-- Layer 2: Dégradé noir très fort à gauche pour garantir la lisibilité du texte -->
		<div class="hero__gradient"></div>
		<!-- Layer 3: Halo lumineux d'accentuation dynamique -->
		<div class="hero__glow"></div>
		<!-- Layer 4: Subtle grid overlay -->
		<div class="hero__grid"></div>
		<!-- Layer 5: Film grain noise -->
		<div class="hero__grain"></div>
	</div>

	<!-- HUD Corner Brackets -->
	<div class="hero__visor hero__visor--tl" aria-hidden="true"></div>
	<div class="hero__visor hero__visor--br" aria-hidden="true"></div>

	<!-- HUD Metadata Panel — top-right -->
	<div class="hero__hud-meta" aria-hidden="true">
		<span class="hero__hud-dot"></span>
		<span>REC_ACTIVE</span>
		<span class="hero__hud-sep">|</span>
		<span>RES: 3840×2160</span>
		<span class="hero__hud-sep">|</span>
		<span>FPS: 59.94</span>
	</div>

	<div class="hero__inner">
		<p class="eyebrow hero__eyebrow reveal">
			<span class="hero__eyebrow-prefix" aria-hidden="true">///</span>
			Studio de création 3D & logicielle _
		</p>

		<h1
			id="hero-title"
			class="hero__title h-display reveal balance"
			style="--delay:.15s"
		>
			Créateurs<br />
			<span class="mark-gradient">de réalités</span><br />
			numériques<span class="hero__cursor" aria-hidden="true">_</span>
		</h1>

		<p class="hero__lead reveal" style="--delay:.3s">
			Site internet, identité visuelle, vidéo de marque, modélisation 3D.
			Quatre métiers&nbsp;— une seule signature&nbsp;: <em>Our Skillz, Your ID</em>.
		</p>

		<div class="hero__actions reveal" style="--delay:.45s">
			<a class="btn btn--primary" href="#contact">
				<span>[ DÉMARRER_PROJET ]</span>
				<svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
					<path d="M2 8h12M9 3l5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</a>
			<a class="btn btn--ghost" href="#realisations">
				<span>VOIR_TRAVAIL</span>
			</a>
		</div>

		<dl class="hero__stats reveal" style="--delay:.6s">
			{stats.map((s, i) => (
				<div class="hero__stat" data-index={i}>
					<dt>{s.value}</dt>
					<dd>{s.label}</dd>
				</div>
			))}
		</dl>
	</div>

	<!-- Mountain ridge transitioning to the cream Solutions section below. -->
	<MountainRidge fill="#F2EEE5" variant="ridge" />
</section>

<style>
	.hero {
		position: relative;
		min-height: 100dvh;
		min-height: 100vh;
		display: flex;
		align-items: center;
		padding-block: calc(var(--header-height) + 3rem) clamp(8rem, 14vw, 14rem);
		overflow: hidden;
		isolation: isolate;
		/* Hero is always dark; force light text regardless of theme */
		--hero-text: #F2EEE5;
		--hero-text-muted: color-mix(in oklab, #F2EEE5 78%, transparent);
		--hero-text-soft: color-mix(in oklab, #F2EEE5 55%, transparent);
	}
	@media (max-width: 640px) {
		.hero {
			min-height: 85dvh;
			padding-block: calc(var(--header-height) + 2rem) clamp(5rem, 10vw, 9rem);
		}
	}

	/* ── HUD Background Layers ──────────────────────────────────────── */
	.hero__bg {
		position: absolute;
		inset: 0;
		z-index: -2;
	}
	.hero__base {
		position: absolute;
		inset: 0;
		background: #0A0A0A;
	}
	.hero__image-sim {
		position: absolute;
		inset: 0;
		background-image: url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop');
		background-size: cover;
		background-position: center;
		filter: grayscale(20%) contrast(120%);
		opacity: 0.4;
		animation: slowPan 20s ease-in-out infinite alternate;
	}
	@keyframes slowPan {
		0% { transform: scale(1.05) translate(0, 0); }
		100% { transform: scale(1.1) translate(-1%, -1%); }
	}
	.hero__gradient {
		position: absolute;
		inset: 0;
		background: linear-gradient(to right, #000 0%, rgba(0,0,0,0.8) 50%, rgba(0,0,0,0) 100%);
	}
	.hero__glow {
		position: absolute;
		top: 25%;
		right: 25%;
		width: 600px;
		height: 600px;
		background: #3A1F3D;
		opacity: 0.2;
		filter: blur(120px);
		border-radius: 50%;
		mix-blend-mode: screen;
		pointer-events: none;
	}
	.hero__grid {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(255,255,255, 0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255,255,255, 0.04) 1px, transparent 1px);
		background-size: 60px 60px;
		pointer-events: none;
	}
	.hero__grain {
		position: absolute;
		inset: 0;
		opacity: 0.05;
		pointer-events: none;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
	}

	/* ── HUD Corner Visors ───────────────────────────────────────────── */
	.hero__visor {
		position: absolute;
		width: clamp(2rem, 5vw, 4rem);
		height: clamp(2rem, 5vw, 4rem);
		pointer-events: none;
		z-index: 5;
	}
	.hero__visor--tl {
		top: calc(var(--header-height) + 1rem);
		left: clamp(1rem, 3vw, 2.5rem);
		border-top: 1px solid var(--color-ocre);
		border-left: 1px solid var(--color-ocre);
		opacity: 0.6;
	}
	.hero__visor--br {
		bottom: clamp(6rem, 12vw, 10rem);
		right: clamp(1rem, 3vw, 2.5rem);
		border-bottom: 1px solid var(--color-ocre);
		border-right: 1px solid var(--color-ocre);
		opacity: 0.6;
	}

	/* ── HUD Metadata Panel ──────────────────────────────────────────── */
	.hero__hud-meta {
		position: absolute;
		top: calc(var(--header-height) + 1.5rem);
		right: clamp(1.5rem, 4vw, 3.5rem);
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--font-mono);
		font-size: 0.65rem;
		letter-spacing: 0.1em;
		color: color-mix(in oklab, var(--color-ocre) 70%, transparent);
		text-transform: uppercase;
		z-index: 5;
	}
	.hero__hud-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #E74C3C;
		animation: hudDotPulse 2s ease-in-out infinite;
	}
	@keyframes hudDotPulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.3; }
	}
	.hero__hud-sep {
		opacity: 0.35;
	}
	@media (max-width: 768px) {
		.hero__hud-meta {
			display: none;
		}
	}

	/* ── Hero Content ────────────────────────────────────────────────── */
	.hero__inner {
		position: relative;
		width: var(--container);
		margin-inline: auto;
		display: flex;
		flex-direction: column;
		gap: 1.4rem;
		max-width: 64rem;
		z-index: 4;
	}

	.hero__eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--hero-text-muted);
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}
	.hero__eyebrow-prefix {
		color: var(--color-ocre);
		font-weight: 700;
	}
	.hero__eyebrow::before {
		display: none;
	}

	.hero__title {
		max-width: 18ch;
		color: var(--hero-text);
		font-weight: 700;
	}
	.hero__title .mark-gradient {
		display: inline-block;
	}
	.hero__cursor {
		color: var(--color-ocre);
		animation: heroCursorBlink 1.2s step-end infinite;
	}
	@keyframes heroCursorBlink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}

	.hero__lead {
		max-width: 38rem;
		font-size: clamp(1.05rem, 1.4vw + 0.5rem, 1.35rem);
		color: var(--hero-text-muted);
		line-height: 1.55;
		font-weight: 300;
	}
	.hero__lead em {
		font-family: var(--font-mono);
		font-style: normal;
		color: var(--color-ocre);
		font-size: 0.9em;
	}
	.hero__eyebrow {
		color: var(--hero-text-muted);
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 0.5rem;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.85rem 1.4rem;
		border-radius: 2px;
		font-family: var(--font-mono);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		transition:
			transform 0.3s var(--ease-emphatic),
			background 0.2s,
			color 0.2s,
			border-color 0.2s;
	}
	.btn--primary {
		background: var(--color-ocre);
		color: #080808;
	}
	.btn--primary:hover {
		transform: translateY(-2px);
		background: #D4A855;
	}
	.btn--ghost {
		background: transparent;
		color: var(--hero-text);
		border: 1px solid color-mix(in oklab, var(--hero-text) 32%, transparent);
	}
	.btn--ghost:hover {
		background: var(--hero-text);
		color: #080808;
		border-color: var(--hero-text);
	}

	/* ── Stats divider ──────────────────────────────────────────────── */
	.hero__stats {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.5rem 2.5rem;
		margin-top: 2.25rem;
		padding-top: 1.75rem;
		position: relative;
		border-top: 1px solid color-mix(in oklab, var(--color-ocre) 25%, transparent);
	}
	.hero__stats::before {
		content: "";
		position: absolute;
		top: -1px;
		left: 0;
		height: 2px;
		width: 0;
		background: linear-gradient(
			90deg,
			var(--accent-cool) 0%,
			var(--accent-cool-soft) 60%,
			transparent 100%
		);
		transition: width 1.2s var(--ease-emphatic) 0.7s;
	}
	.hero__stats.is-visible::before {
		width: 30%;
	}
	@media (prefers-reduced-motion: reduce) {
		.hero__stats::before { width: 30%; transition: none; }
	}
	.hero__stat:hover dt {
		color: var(--color-ocre);
		transition: color 0.3s var(--ease-soft);
	}
	.hero__stat dt {
		font-family: var(--font-display);
		font-size: clamp(1.15rem, 1.5vw + 0.5rem, 1.65rem);
		font-weight: 600;
		color: var(--hero-text);
		line-height: 1;
		letter-spacing: -0.02em;
	}
	.hero__stat dd {
		margin: 0.4rem 0 0;
		font-family: var(--font-mono);
		font-size: 0.68rem;
		font-weight: 400;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--hero-text-soft);
	}

	@media (max-width: 768px) {
		.hero__stats {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1.25rem 1.5rem;
		}
	}

	/* ── Mountain ridge palette swap on light theme ─────────────────── */
	:root[data-theme="light"] .hero .mountain-ridge svg path {
		fill: #F2EEE5;
	}
	@media (prefers-color-scheme: light) {
		:root:not([data-theme]) .hero .mountain-ridge svg path {
			fill: #F2EEE5;
		}
	}

	/* ── Reveal cascade ─────────────────────────────────────────────── */
	.reveal {
		transition-delay: var(--delay, 0s);
	}

	@media (prefers-reduced-motion: reduce) {
		.hero__hud-dot { animation: none; opacity: 1; }
		.hero__cursor { animation: none; opacity: 1; }
	}
</style>
