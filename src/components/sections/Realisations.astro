---
/**
 * Realisations — section "carousel projets" mood "cream".
 *
 * Hero rhythm continues: cream paper background, large editorial title with
 * mark-gradient, lead, then a 3-up center-focused auto-rotating carousel
 * (Splide) showing the 19 portfolio entries in random-ish order. Hover on
 * the centered card auto-plays the linked video; side cards stay quiet,
 * scaled down and slightly desaturated.
 *
 * Anchor: #realisations
 */
import RealisationsCarousel from "../islands/RealisationsCarousel";
import { projects } from "../../lib/site";
---

<section
	id="realisations"
	class="reals section-cream section-pad"
	data-section-mood="cream"
	aria-labelledby="reals-title"
>
	<header class="reals__header">
		<p class="eyebrow reveal">Réalisations</p>
		<h2 id="reals-title" class="h-1 reveal balance" style="--delay:.1s">
			Du <span class="mark-gradient">terrain</span>, des
			<span class="mark-gradient">marques</span>,
			une signature.
		</h2>
		<p class="reals__lead reveal" style="--delay:.2s">
			Marques de sport (Subway, Adidas, Sofiane Oumiha), restaurants,
			programmes immobiliers&nbsp;3D&nbsp;: chaque projet a son histoire.
			Quelques extraits des derniers mois — survolez la carte centrale pour
			lancer la vidéo.
		</p>
	</header>

	<div class="reals__carousel-wrap reveal" style="--delay:.3s">
		<RealisationsCarousel projects={[...projects]} client:visible />
	</div>

	<footer class="reals__footer reveal" style="--delay:.4s">
		<a class="reals__more" href="#contact">
			<span>Confier un projet</span>
			<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M5 12h14M13 5l7 7-7 7" />
			</svg>
		</a>
	</footer>
</section>

<style>
	.reals {
		position: relative;
		background: #080808;
	}
	.reals__header {
		width: var(--container);
		margin-inline: auto;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding-bottom: 3rem;
	}
	.reals__lead {
		max-width: 32rem;
		color: var(--text-muted);
		font-size: 1.1rem;
		line-height: 1.6;
	}
	.reals__carousel-wrap {
		width: 100%;
		overflow: hidden;
	}
	.reals__footer {
		display: flex;
		justify-content: center;
		padding-top: 4rem;
	}

	:global(.rcarousel) {
		position: relative;
	}
	:global(.rcarousel__slide) {
		transition: all 0.6s var(--ease-emphatic);
	}
	:global(.rcarousel__slide:not(.is-active)) {
		opacity: 0.3;
		transform: scale(0.85);
		filter: grayscale(1) blur(2px);
	}
	:global(.rcarousel__card) {
		position: relative;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border);
		transition: all 0.4s var(--ease-soft);
	}
	:global(.rcarousel__slide.is-active .rcarousel__card) {
		border-color: var(--tech);
		background: rgba(255, 255, 255, 0.05);
	}
	:global(.rcarousel__media) {
		position: relative;
		aspect-ratio: 4/5;
		overflow: hidden;
	}
	:global(.rcarousel__poster),
	:global(.rcarousel__video) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.8;
		transition: all 0.6s var(--ease-soft);
	}
	:global(.rcarousel__slide.is-active .rcarousel__card:hover .rcarousel__poster) {
		transform: scale(1.05);
		opacity: 1;
	}

	:global(.rcarousel__hud-overlay) {
		position: absolute;
		inset: 0;
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		pointer-events: none;
		z-index: 2;
		font-family: var(--font-mono);
		font-size: 0.6rem;
		color: var(--tech);
		opacity: 0;
		transition: opacity 0.4s var(--ease-soft);
	}
	:global(.rcarousel__slide.is-active .rcarousel__hud-overlay) {
		opacity: 1;
	}
	:global(.rcarousel__hud-overlay .top) {
		display: flex;
		justify-content: space-between;
	}
	:global(.rcarousel__hud-overlay .bottom) {
		display: flex;
		justify-content: flex-end;
	}

	:global(.rcarousel__info) {
		padding: 1.5rem;
		border-top: 1px solid var(--border);
	}
	:global(.rcarousel__cardtitle) {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: #fff;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	:global(.rcarousel__caption) {
		width: var(--container);
		margin: 4rem auto 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	:global(.rcarousel__metadata) {
		display: flex;
		gap: 2rem;
		font-family: var(--font-mono);
		font-size: 0.65rem;
		color: var(--tech);
		opacity: 0.6;
	}
	:global(.rcarousel__title) {
		font-size: 2rem;
		font-weight: 700;
		color: #fff;
		max-width: 20ch;
	}
	:global(.rcarousel__summary) {
		font-family: var(--font-mono);
		font-size: 0.9rem;
		line-height: 1.6;
		color: var(--text-muted);
		max-width: 36rem;
	}

	:global(.rcarousel__arrow) {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		width: 3.5rem;
		height: 3.5rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--border);
		color: var(--tech);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.3s var(--ease-soft);
		z-index: 10;
	}
	:global(.rcarousel__arrow:hover) {
		background: rgba(255, 255, 255, 0.1);
		border-color: var(--tech);
		box-shadow: 0 0 15px var(--tech);
	}
	:global(.rcarousel__arrow--prev) { left: 2rem; }
	:global(.rcarousel__arrow--next) { right: 2rem; }

	:global(.rcarousel__pagination) {
		display: flex;
		justify-content: center;
		gap: 1rem;
		margin-top: 3rem;
	}
	:global(.rcarousel__page) {
		width: 6px;
		height: 6px;
		background: var(--border-strong);
		transform: rotate(45deg);
		transition: all 0.3s var(--ease-soft);
	}
	:global(.rcarousel__page.is-active) {
		background: var(--tech);
		box-shadow: 0 0 8px var(--tech);
	}

	@media (max-width: 1023px) {
		:global(.rcarousel__arrow) { display: none; }
		:global(.rcarousel__slide:not(.is-active)) { opacity: 0; }
	}
</style>
