---
import { clients } from "../../lib/site";

// Duplicate so the marquee can scroll seamlessly
const row = [...clients, ...clients];
---

<section class="marquee-section" aria-label="Marques accompagnées">
	<p class="eyebrow reveal">Ils nous font confiance</p>
	<div class="marquee">
		<div class="marquee-track" style="--marquee-duration: 50s; --marquee-gap: 4rem;">
			{row.map((c) => (
				<div class="logo-tile" title={c.name}>
					{c.logo ? (
						<span
							class="logo-mask"
							style={`--logo-src: url(${c.logo})`}
							role="img"
							aria-label={c.name}
						></span>
					) : (
						<span class="logo-text" aria-label={c.name}>
							{(c as any).label ?? c.name}
						</span>
					)}
				</div>
			))}
		</div>
	</div>
	<div class="marquee">
		<div
			class="marquee-track"
			data-direction="reverse"
			style="--marquee-duration: 65s; --marquee-gap: 4rem;"
		>
			{row.reverse().map((c) => (
				<div class="logo-tile" title={c.name}>
					{c.logo ? (
						<span
							class="logo-mask"
							style={`--logo-src: url(${c.logo})`}
							role="img"
							aria-label={c.name}
						></span>
					) : (
						<span class="logo-text" aria-label={c.name}>
							{(c as any).label ?? c.name}
						</span>
					)}
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.marquee-section {
		padding: 5rem 0 6rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		overflow: hidden;
		border-block: 1px solid var(--border);
		background: var(--bg-elevated);
	}
	.marquee-section .eyebrow {
		text-align: center;
	}
	.marquee {
		overflow: hidden;
		mask-image: linear-gradient(
			to right,
			transparent,
			black 8%,
			black 92%,
			transparent
		);
		-webkit-mask-image: linear-gradient(
			to right,
			transparent,
			black 8%,
			black 92%,
			transparent
		);
	}
	.logo-tile {
		flex: 0 0 auto;
		width: clamp(7rem, 12vw, 11rem);
		height: clamp(3rem, 6vw, 4.5rem);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--text-muted);
		opacity: 0.55;
		transition: color 0.3s, opacity 0.3s;
	}
	.logo-tile:hover {
		color: var(--accent);
		opacity: 1;
	}
	.logo-tile .logo-mask {
		display: block;
		width: 100%;
		height: 100%;
	}
	.logo-text {
		font-family: var(--font-display);
		font-size: clamp(1.25rem, 1.6vw, 1.6rem);
		font-style: italic;
		font-variation-settings: "opsz" 144, "SOFT" 80;
		letter-spacing: -0.01em;
		white-space: nowrap;
	}
</style>
