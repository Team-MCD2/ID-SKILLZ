---
/**
 * Partners — section "scroll-tied slideshow" mood "warm-dark".
 *
 * Pinned-feel section (~1.5 viewport-heights of scroll travel). The
 * outer wrapper is tall, the inner `partners__stage` is sticky and the
 * N logo sets cross-fade progressively based on scroll progress. Each
 * set shows a 2×2 grid of 4 brand badges + its synchronized editorial
 * phrase. On the right, a sticky text panel stays pinned with title +
 * CTA leading to #realisations.
 *
 * Why not React island? The cross-fade is purely scroll-driven with a
 * single passive listener — no need for React state. We also reuse
 * ClientBadge.astro directly (cleaner than duplicating SVG in JSX).
 *
 * Anchor: #partners
 */
import { partnerSlides, clients } from "../../lib/site";
import ClientBadge from "../ClientBadge.astro";

// Resolve each partner slide's logo strings to the full client objects
// so ClientBadge gets the correct name + label. Guards against missing
// entries at build time.
const slides = partnerSlides.map((s) => ({
	logos: s.logos.map((name) => {
		const c = clients.find((x) => x.name === name);
		return c ?? { name, label: name };
	}),
	phrase: s.phrase,
}));
---

<section
	id="partners"
	class="partners"
	data-section-mood="warm-dark"
	aria-labelledby="partners-title"
	data-scroll-tied
>
	<h2 id="partners-title" class="visually-hidden">
		Partenaires & Clients
	</h2>

	<div class="partners__wrap">
		<div class="partners__stage">
			<div class="partners__inner">
				<!-- LEFT: the logo grid -->
				<div class="partners__stack" aria-live="polite">
					{slides.map((s, i) => (
						<div class="partners__slide" data-index={i} aria-hidden={i !== 0}>
							<div class="partners__grid">
								{s.logos.map((c, j) => (
									<div class="partners__tile corner-brackets" style={`--j:${j}`}>
										<ClientBadge name={c.name} label={c.label} />
									</div>
								))}
							</div>
							<div class="partners__metadata">
								<span class="nav-num">// LOG_SESSION_ACTIVE</span>
								<p class="partners__phrase">{s.phrase}</p>
							</div>
						</div>
					))}
				</div>

				<!-- RIGHT: editorial panel -->
				<aside class="partners__panel">
					<p class="eyebrow"><span class="eyebrow-prefix">///</span> ÉCOSYSTÈME_CLIENTS</p>
					<h3 class="h-2">
						Restauration, sport, industrie, lifestyle — on prend
						<span class="mark-gradient">le même virage</span>
						avec chacun.
					</h3>
					
					<div class="partners__actions">
						<a class="btn-hud" href="#realisations">
							Voir_Projets
						</a>
						
						<div class="partners__counter" aria-label="Index des partenaires">
							{slides.map((_, i) => (
								<div 
									class="partners__tick" 
									data-dot={i}
									aria-selected={i === 0}
								></div>
							))}
							<span class="partners__idx">01 / {slides.length}</span>
						</div>
					</div>
				</aside>
			</div>
		</div>
	</div>
</section>

<script>
	(() => {
		const section = document.querySelector<HTMLElement>(".partners[data-scroll-tied]");
		if (!section) return;
		const wrap = section.querySelector<HTMLElement>(".partners__wrap");
		const slides = Array.from(section.querySelectorAll<HTMLElement>(".partners__slide"));
		const ticks = Array.from(section.querySelectorAll<HTMLElement>(".partners__tick"));
		const idxLabel = section.querySelector<HTMLElement>(".partners__idx");
		if (!wrap || slides.length === 0) return;

		const setActive = (idx: number) => {
			slides.forEach((s, i) => {
				const on = i === idx;
				s.setAttribute("aria-hidden", String(!on));
				s.dataset.active = on ? "true" : "false";
			});
			ticks.forEach((t, i) => {
				t.setAttribute("aria-selected", String(i === idx));
			});
			if (idxLabel) {
				idxLabel.textContent = `0${idx + 1} / ${slides.length}`;
			}
		};
		setActive(0);

		let ticking = false;
		const onScroll = () => {
			if (ticking) return;
			ticking = true;
			requestAnimationFrame(() => {
				const rect = wrap.getBoundingClientRect();
				const total = rect.height - window.innerHeight;
				if (total <= 0) { ticking = false; return; }
				const raw = Math.max(0, Math.min(1, -rect.top / total));
				const idx = Math.min(slides.length - 1, Math.floor(raw * slides.length));
				setActive(idx);
				ticking = false;
			});
		};
		window.addEventListener("scroll", onScroll, { passive: true });
		window.addEventListener("resize", onScroll);
	})();
</script>

<style>
	.partners {
		position: relative;
		background: #080808;
	}

	.partners__wrap {
		position: relative;
		height: 250vh;
	}

	.partners__stage {
		position: sticky;
		top: 0;
		height: 100vh;
		display: flex;
		align-items: center;
		padding-inline: var(--gutter);
		overflow: hidden;
	}

	.partners__inner {
		width: 100%;
		max-width: 80rem;
		margin-inline: auto;
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		align-items: center;
	}
	@media (min-width: 1024px) {
		.partners__inner {
			grid-template-columns: 1.2fr 1fr;
			gap: 6rem;
		}
	}

	.partners__stack {
		position: relative;
		width: 100%;
		aspect-ratio: 4 / 3;
		max-height: 35rem;
	}

	.partners__slide {
		position: absolute;
		inset: 0;
		opacity: 0;
		transform: translateY(20px);
		transition: all 0.6s var(--ease-emphatic);
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}
	.partners__slide[data-active="true"] {
		opacity: 1;
		transform: translateY(0);
	}

	.partners__grid {
		flex: 1;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		grid-template-rows: repeat(2, 1fr);
		gap: 1rem;
	}

	.partners__tile {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--border);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		transition: all 0.4s var(--ease-soft);
	}
	.partners__tile:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: var(--tech);
	}

	.partners__metadata {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.nav-num {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		color: var(--tech);
		opacity: 0.6;
	}
	.partners__phrase {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--text-soft);
		letter-spacing: 0.02em;
	}

	.partners__panel {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.partners__actions {
		display: flex;
		align-items: center;
		gap: 2rem;
		margin-top: 1rem;
	}

	.partners__counter {
		display: flex;
		align-items: center;
		gap: 1rem;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--tech);
	}

	.partners__tick {
		width: 4px;
		height: 4px;
		background: var(--border-strong);
		transform: rotate(45deg);
	}
	.partners__tick[aria-selected="true"] {
		background: var(--tech);
		box-shadow: 0 0 8px var(--tech);
	}

	@media (max-width: 1023px) {
		.partners__wrap { height: auto; }
		.partners__stage { 
			position: relative; 
			height: auto; 
			padding-block: 6rem;
		}
		.partners__stack { 
			aspect-ratio: auto; 
			height: auto;
			max-height: none;
		}
		.partners__slide { 
			position: relative; 
			opacity: 1; 
			transform: none;
			margin-bottom: 4rem;
		}
		.partners__slide:not(:first-child) { display: none; }
		.partners__counter { display: none; }
	}
</style>
