---
import { services } from "../../lib/site";
---

<section
	id="services"
	class="services section-warm-dark"
	data-section-mood="warm-dark"
	aria-labelledby="services-title"
>
	<header class="services__header section-pad-top">
		<p class="eyebrow reveal"><span class="eyebrow-prefix">///</span> DEPLOYMENT_CATALOG</p>
		<h2 id="services-title" class="h-1 reveal" style="--delay:.1s">
			Tout ce qu&rsquo;il faut pour
			<span class="mark-gradient">prendre la parole</span>,
			sous contrôle.
		</h2>
		<p class="services__lead reveal" style="--delay:.2s">
			Site web, design, vidéo, 3D&nbsp;: chaque projet est piloté
			en interne. Pas de sous-traitance, pas de dilution de qualité.
			Performance technique et esthétique garantie.
		</p>
	</header>

	<div class="services__grid">
		{services.map((s, i) => (
			<article class="service-card reveal corner-brackets" style={`--delay:${0.05 * i + 0.2}s`} data-card={s.slug}>
				<div class="service-card__media" aria-hidden="true">
					<video
						class="service-card__video"
						src={s.video}
						muted
						loop
						playsinline
						preload="none"
						poster={s.poster}
					></video>
					<img class="service-card__poster" src={s.poster} alt="" loading="lazy" />
					<div className="service-card__hud">
						<span>// RAW_FEED: 0{i + 1}</span>
						<span>SECURE_LINK</span>
					</div>
				</div>

				<div class="service-card__body">
					<div class="service-card__meta">
						<span class="service-card__num">[ SERVICE_0{i + 1} ]</span>
						<span class="service-card__uid">0x{s.slug.slice(0, 3).toUpperCase()}</span>
					</div>
					<h3 class="service-card__title">{s.title}</h3>
					<p class="service-card__summary">{s.summary}</p>
					
					<div class="service-card__specs">
						<span class="specs-label">// TECHNICAL_DELIVERABLES</span>
						<ul class="service-card__offerings">
							{s.offerings.map((o) => (
								<li>
									<span class="o-key">{o.name.toUpperCase()}</span>
									<span class="o-val">{o.body}</span>
								</li>
							))}
						</ul>
					</div>
					
					<a class="btn-hud" href={`#realisations`}>
						EXPLORE_LOGS
					</a>
				</div>
			</article>
		))}
	</div>
</section>

<style>
	.services {
		position: relative;
		background: #080808;
	}
	.services__header {
		width: var(--container);
		margin-inline: auto;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding-bottom: 3rem;
	}
	.services__lead {
		max-width: 32rem;
		color: var(--text-muted);
		font-size: 1.1rem;
		line-height: 1.6;
	}

	.services__grid {
		width: var(--container);
		margin-inline: auto;
		display: grid;
		gap: 2rem;
		grid-template-columns: 1fr;
	}
	@media (min-width: 768px) {
		.services__grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.service-card {
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border);
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		transition: all 0.4s var(--ease-soft);
	}
	.service-card:hover {
		background: rgba(255, 255, 255, 0.05);
		border-color: var(--tech);
	}

	.service-card__media {
		position: relative;
		aspect-ratio: 16/9;
		overflow: hidden;
		background: #000;
		border: 1px solid var(--border);
	}
	.service-card__video,
	.service-card__poster {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.6;
		filter: grayscale(1);
		transition: all 0.6s var(--ease-soft);
	}
	.service-card:hover .service-card__video,
	.service-card:hover .service-card__poster {
		opacity: 0.8;
		filter: grayscale(0.5);
	}

	.service-card__hud {
		position: absolute;
		top: 1rem;
		left: 1rem;
		right: 1rem;
		display: flex;
		justify-content: space-between;
		font-family: var(--font-mono);
		font-size: 0.55rem;
		color: var(--tech);
		pointer-events: none;
	}

	.service-card__body {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.service-card__meta {
		display: flex;
		justify-content: space-between;
		font-family: var(--font-mono);
		font-size: 0.65rem;
		color: var(--tech);
	}

	.service-card__title {
		font-size: 1.5rem;
		font-weight: 700;
		color: #fff;
	}
	.service-card__summary {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		line-height: 1.6;
		color: var(--text-muted);
	}

	.service-card__specs {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding-top: 1rem;
		border-top: 1px solid var(--border);
	}
	.specs-label {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		color: var(--tech);
		opacity: 0.6;
	}

	.service-card__offerings {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.service-card__offerings li {
		display: grid;
		grid-template-columns: 8rem 1fr;
		gap: 1rem;
		font-family: var(--font-mono);
		font-size: 0.75rem;
	}
	.o-key {
		color: #fff;
		font-weight: 600;
	}
	.o-val {
		color: var(--text-soft);
	}

	@media (max-width: 480px) {
		.service-card__offerings li {
			grid-template-columns: 1fr;
			gap: 0.25rem;
		}
	}
</style>

<script>
	const cards = document.querySelectorAll<HTMLElement>("[data-card]");
	cards.forEach((card) => {
		const video = card.querySelector<HTMLVideoElement>("video");
		if (!video) return;
		card.addEventListener("mouseenter", () => {
			video.play().catch(() => {});
		});
		card.addEventListener("mouseleave", () => {
			video.pause();
			video.currentTime = 0;
		});
	});
</script>
