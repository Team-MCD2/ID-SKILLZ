---
import { services } from "../../lib/site";
---

<section id="services" class="services" aria-labelledby="services-title">
	<header class="services__header">
		<p class="eyebrow reveal">Quatre métiers · une signature</p>
		<h2 id="services-title" class="h-1 reveal" style="--delay:.1s">
			Tout ce qu&rsquo;il faut pour
			<span class="mark-gradient">prendre la parole</span>,
			fait sous le même toit.
		</h2>
		<p class="services__lead reveal" style="--delay:.2s">
			Site web, design, vidéo, 3D&nbsp;: chacun de nos métiers est piloté
			en interne par des spécialistes qui ne sous-traitent jamais le cœur du projet.
			C&rsquo;est ce qui nous permet de tenir nos délais, nos budgets et notre exigence.
		</p>
	</header>

	<div class="services__grid">
		{services.map((s, i) => (
			<article class="service-card reveal" style={`--delay:${0.05 * i + 0.2}s`} data-card={s.slug}>
				<div class="service-card__media" aria-hidden="true">
					<video
						class="service-card__video"
						src={s.video}
						muted
						loop
						playsinline
						preload="none"
						poster={s.poster}
					></video>
					<img class="service-card__poster" src={s.poster} alt="" loading="lazy" />
				</div>

				<div class="service-card__body">
					<div class="service-card__meta">
						<span class="service-card__index">{s.index}</span>
						<span class="service-card__eyebrow">{s.eyebrow}</span>
					</div>
					<h3 class="service-card__title">{s.title}</h3>
					<p class="service-card__summary">{s.summary}</p>
					<ul class="service-card__offerings">
						{s.offerings.map((o) => (
							<li>
								<strong>{o.name}</strong>
								<span>{o.body}</span>
							</li>
						))}
					</ul>
					<a class="service-card__cta" href={`#realisations`}>
						<span>Voir des réalisations {s.title.toLowerCase()}</span>
						<svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
							<path d="M2 8h12M9 3l5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
					</a>
				</div>
			</article>
		))}
	</div>
</section>

<style>
	.services {
		padding: 6rem 0 8rem;
	}
	.services__header {
		width: var(--container-narrow);
		margin: 0 auto 4rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		max-width: 50rem;
	}
	.services__lead {
		font-size: clamp(1rem, 0.9vw + 0.6rem, 1.15rem);
		color: var(--text-muted);
		max-width: 36rem;
		line-height: 1.65;
	}

	.services__grid {
		width: var(--container);
		margin-inline: auto;
		display: grid;
		gap: 1.5rem;
		grid-template-columns: 1fr;
	}
	@media (min-width: 768px) {
		.services__grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.service-card {
		display: grid;
		grid-template-rows: auto 1fr;
		gap: 1rem;
		padding: 1.25rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 1.25rem;
		transition:
			background 0.4s var(--ease-emphatic),
			border-color 0.4s var(--ease-emphatic),
			transform 0.4s var(--ease-emphatic);
	}
	.service-card:hover {
		background: var(--surface-hover);
		border-color: var(--border-strong);
		transform: translateY(-2px);
	}

	.service-card__media {
		position: relative;
		aspect-ratio: 16 / 10;
		border-radius: 0.75rem;
		overflow: hidden;
		background: var(--bg);
	}
	.service-card__video,
	.service-card__poster {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.service-card__video {
		opacity: 0;
		transition: opacity 0.4s var(--ease-emphatic);
		filter: grayscale(0.4) contrast(1.05);
	}
	.service-card__poster {
		opacity: 1;
		transition: opacity 0.4s var(--ease-emphatic);
		filter: grayscale(0.4) contrast(1.05);
	}
	.service-card:hover .service-card__video {
		opacity: 1;
	}
	.service-card:hover .service-card__poster {
		opacity: 0;
	}

	.service-card__body {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 0.5rem 0.5rem 0.75rem;
	}
	.service-card__meta {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		color: var(--text-soft);
		font-size: 0.75rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}
	.service-card__index {
		font-family: var(--font-mono);
		color: var(--color-ocre);
		font-weight: 500;
	}
	.service-card__eyebrow {
		font-style: italic;
		text-transform: none;
		letter-spacing: 0;
		font-family: var(--font-display);
		color: var(--text-muted);
		font-size: 0.95rem;
		text-align: right;
	}
	.service-card__title {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 2.4vw + 0.3rem, 2.5rem);
		line-height: 1.05;
		color: var(--text);
	}
	.service-card__summary {
		color: var(--text-muted);
		font-size: 0.95rem;
		line-height: 1.55;
	}
	.service-card__offerings {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		border-top: 1px solid var(--border);
		padding-top: 1rem;
	}
	.service-card__offerings li {
		display: grid;
		grid-template-columns: minmax(8rem, 12rem) 1fr;
		gap: 0.75rem;
		font-size: 0.85rem;
	}
	.service-card__offerings strong {
		font-weight: 500;
		color: var(--text);
	}
	.service-card__offerings span {
		color: var(--text-muted);
	}
	@media (max-width: 480px) {
		.service-card__offerings li {
			grid-template-columns: 1fr;
			gap: 0.1rem;
		}
	}

	.service-card__cta {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--accent);
		font-size: 0.85rem;
		font-weight: 500;
		padding-top: 0.5rem;
		width: fit-content;
		transition: gap 0.3s var(--ease-emphatic);
	}
	.service-card__cta:hover {
		gap: 0.75rem;
	}

	.reveal {
		transition-delay: var(--delay, 0s);
	}
</style>

<script>
	// Hover-trigger video play (autoplay only when card is in viewport AND hovered)
	const cards = document.querySelectorAll<HTMLElement>("[data-card]");
	cards.forEach((card) => {
		const video = card.querySelector<HTMLVideoElement>("video");
		if (!video) return;
		card.addEventListener("mouseenter", () => {
			video.play().catch(() => {});
		});
		card.addEventListener("mouseleave", () => {
			video.pause();
			video.currentTime = 0;
		});
	});
</script>
