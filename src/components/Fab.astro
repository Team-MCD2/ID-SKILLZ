---
/**
 * Fab — Persistent floating action pill, fixed bottom-center.
 *
 * Two segments, modeled on Websenso's signature affordance:
 *   1. Italic-serif "Prendre contact" CTA on the left (highest priority).
 *   2. Sans "MENU" toggle on the right (opens the off-canvas nav overlay).
 *
 * Adaptive theming: a tiny client-side `IntersectionObserver` watches every
 * `[data-section-mood]` ancestor scroll into view and updates the FAB's
 * `data-mood` attribute so the pill swaps between dark and cream surfaces
 * depending on which section is dominant. Falls back to dark mood if no
 * sections declare moods.
 */
import { site } from "../lib/site";

interface Props {
	contactHref?: string;
	defaultMood?: "warm-dark" | "cream";
}

const {
	contactHref = "#contact",
	defaultMood = "warm-dark",
} = Astro.props;

const phoneHref = `tel:${site.phone}`;
---

<aside
	class="fab"
	role="complementary"
	aria-label="Contrôles HUD"
>
	<div class="fab__status" aria-hidden="true">
		<span class="fab__dot"></span>
		SYS_READY
	</div>
	
	<a class="fab__action fab__action--primary" href={contactHref} data-fab-action="contact">
		[ NOUS_CONTACTER ]
	</a>
	
	<button type="button" class="fab__action" data-fab-action="menu" aria-haspopup="dialog" aria-expanded="false" aria-controls="menu-overlay">
		MENU ///
	</button>
</aside>

<script>
	(() => {
		const fab = document.querySelector<HTMLElement>(".fab");
		if (!fab) return;

		// Menu button controller
		const menuBtn = document.querySelector<HTMLButtonElement>(
			".fab [data-fab-action='menu']",
		);
		
		menuBtn?.addEventListener("click", () => {
			const w = window as unknown as {
				__idskillzToggleMenu?: (open: boolean) => void;
			};
			if (typeof w.__idskillzToggleMenu === "function") {
				const open = menuBtn.getAttribute("aria-expanded") === "true";
				w.__idskillzToggleMenu(!open);
				menuBtn.setAttribute("aria-expanded", String(!open));
			}
		});
	})();
</script>

<style>
	.fab {
		position: fixed;
		bottom: 1.5rem;
		left: 50%;
		transform: translateX(-50%);
		z-index: 100;
		display: flex;
		align-items: center;
		background: rgba(8, 8, 8, 0.85);
		backdrop-filter: blur(16px);
		border: 1px solid var(--border-strong);
		color: #fff;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
		transition: transform 0.4s var(--ease-emphatic);
	}

	.fab__status {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.75rem 1.25rem;
		border-right: 1px solid var(--border);
		color: var(--text-soft);
		font-size: 0.6rem;
	}

	.fab__dot {
		width: 6px;
		height: 6px;
		background: #22c55e;
		border-radius: 50%;
		box-shadow: 0 0 8px #22c55e;
	}

	.fab__action {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.75rem 1.5rem;
		transition: all 0.3s var(--ease-soft);
		border-right: 1px solid var(--border);
		cursor: pointer;
		font-weight: 700;
	}

	.fab__action:last-child {
		border-right: 0;
	}

	.fab__action--primary {
		background: var(--accent);
		color: #fff;
	}

	.fab__action--primary:hover {
		background: var(--accent-soft);
	}

	.fab__action:not(.fab__action--primary):hover {
		background: rgba(255, 255, 255, 0.05);
		color: var(--tech);
	}

	@media (max-width: 640px) {
		.fab {
			bottom: 1rem;
			width: calc(100vw - 2rem);
			justify-content: center;
		}
		.fab__status { display: none; }
		.fab__action {
			flex: 1;
			justify-content: center;
			padding-inline: 0.5rem;
		}
	}
</style>
