---
/**
 * Footer — massive "CONTACT" typography over a warm-dark surface,
 * followed by columns (studios / contact / nav) and a thin bottom strip
 * (legal mentions, partners, microdidact credit).
 *
 * Inspired by the Websenso closing footer; reskinned in ID Skillz tones.
 */
import Brand from "./Brand.astro";
import { site, nav } from "../lib/site";

const year = new Date().getFullYear();
const legals = [
	{ label: "Mentions légales", href: "/mentions-legales" },
	{ label: "Politique de confidentialité", href: "/politique-de-confidentialite" },
];
---

<footer class="site-footer corner-brackets" data-section-mood="warm-dark">
	<div class="site-footer__hero reveal">
		<div class="site-footer__meta">
			<span class="meta-id">[ SYSTEM_END ]</span>
			<span class="meta-log">END_LOG: 0x1A4B</span>
		</div>
		
		<h2 class="site-footer__shout" aria-hidden="true">
			<span class="site-footer__shout-line" style="--li:0">
				<span class="site-footer__shout-inner">CON</span>
			</span>
			<span class="site-footer__shout-line" style="--li:1">
				<span class="site-footer__shout-inner">TACT</span>
			</span>
		</h2>
		
		<a class="site-footer__email" href={`mailto:${site.email}`}>
			<span class="site-footer__email-text">
				{site.email.toUpperCase()}
			</span>
		</a>
	</div>

	<div class="site-footer__inner">
		<div class="site-footer__brand">
			<Brand variant="full" class="site-footer__logo" />
			<p class="site-footer__pitch">
				[ STATUS: OPERATIONAL ] // Anciennement Mwcrea Agency. 
				Studio créatif fondé à Toulouse en 2022. 
				Performance technique et esthétique garantie.
			</p>
		</div>

		<div class="site-footer__col">
			<h4 class="eyebrow"><span class="eyebrow-prefix">///</span> LOCATIONS</h4>
			<address>
				<div class="addr-block">
					<span class="addr-label">PARIS_HQ</span>
					<a href={site.addresses.paris.href} target="_blank" rel="noreferrer">
						{site.addresses.paris.lines.join(", ")}
					</a>
				</div>
				<div class="addr-block">
					<span class="addr-label">TOULOUSE_STUDIO</span>
					<a href={site.addresses.toulouse.href} target="_blank" rel="noreferrer">
						{site.addresses.toulouse.lines.join(", ")}
					</a>
				</div>
			</address>
		</div>

		<div class="site-footer__col">
			<h4 class="eyebrow"><span class="eyebrow-prefix">///</span> CHANNELS</h4>
			<ul class="links">
				<li><a href={`mailto:${site.email}`}>MAIL: {site.email}</a></li>
				<li><a href={`tel:${site.phone}`}>VOICE: {site.phoneFormatted}</a></li>
				<li><a href={site.socials.instagram} target="_blank" rel="noreferrer">INSTAGRAM</a></li>
				<li><a href={site.socials.youtube} target="_blank" rel="noreferrer">YOUTUBE</a></li>
			</ul>
		</div>

		<div class="site-footer__col">
			<h4 class="eyebrow"><span class="eyebrow-prefix">///</span> SYSTEM_MAP</h4>
			<ul class="links">
				{nav.map((item) => (
					<li><a href={item.href}>{item.label.toUpperCase()}</a></li>
				))}
			</ul>
		</div>
	</div>

	<div class="site-footer__bottom">
		<div class="site-footer__bottom-inner">
			<p class="legal-id">
				[ © {year} {site.name} ] // SAS // {site.rcs} // TVA {site.tva}
			</p>
			<ul class="legal-links">
				{legals.map((l) => <li><a href={l.href}>{l.label.toUpperCase()}</a></li>)}
			</ul>
			<p class="microdidact">
				[ ENGINE: <a href="https://microdidact.com" target="_blank" rel="noreferrer">MICRODIDACT</a> ]
			</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		position: relative;
		background: #080808;
		color: #fff;
		border-top: 1px solid var(--border);
		margin-top: 4rem;
	}

	.site-footer__hero {
		width: var(--container);
		margin-inline: auto;
		padding-block: 6rem 4rem;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.site-footer__meta {
		display: flex;
		justify-content: space-between;
		font-family: var(--font-mono);
		font-size: 0.65rem;
		color: var(--tech);
		opacity: 0.8;
	}

	.site-footer__shout {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: clamp(5rem, 20vw, 16rem);
		line-height: 0.8;
		color: #fff;
		margin: 0;
		letter-spacing: -0.05em;
	}
	.site-footer__shout-line { display: block; overflow: hidden; }
	.site-footer__shout-inner {
		display: inline-block;
		transform: translateY(100%);
		transition: transform 0.8s var(--ease-emphatic);
		transition-delay: calc(var(--li, 0) * 100ms);
	}
	.site-footer__hero.is-visible .site-footer__shout-inner { transform: translateY(0); }

	.site-footer__email {
		font-family: var(--font-mono);
		font-size: clamp(1rem, 2vw, 1.5rem);
		color: var(--tech);
		text-decoration: none;
		transition: opacity 0.3s var(--ease-soft);
	}
	.site-footer__email:hover { opacity: 0.7; }

	.site-footer__inner {
		width: var(--container);
		margin-inline: auto;
		display: grid;
		gap: 4rem;
		padding-top: 4rem;
		border-top: 1px solid var(--border);
	}
	@media (min-width: 1024px) {
		.site-footer__inner {
			grid-template-columns: 1.5fr repeat(3, 1fr);
		}
	}

	.site-footer__brand {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.site-footer__pitch {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--text-muted);
		line-height: 1.6;
		max-width: 24rem;
	}

	.site-footer__col {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	address {
		font-style: normal;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.addr-block {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.addr-label {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		color: var(--tech);
		opacity: 0.6;
	}
	address a {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: #fff;
		line-height: 1.4;
	}

	.links {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.links a {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: #fff;
		transition: color 0.3s var(--ease-soft);
	}
	.links a:hover { color: var(--tech); }

	.site-footer__bottom {
		margin-top: 6rem;
		padding-block: 2rem;
		border-top: 1px solid var(--border);
	}
	.site-footer__bottom-inner {
		width: var(--container);
		margin-inline: auto;
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;
		gap: 2rem;
		font-family: var(--font-mono);
		font-size: 0.65rem;
		color: var(--text-soft);
	}

	.legal-links {
		list-style: none;
		padding: 0;
		display: flex;
		gap: 2rem;
	}
	.legal-links a { color: inherit; }
	.legal-links a:hover { color: #fff; }

	.microdidact a { color: var(--tech); }
</style>
