---
/**
 * Brand wordmark — uses the official id-skillz logo PNG (black on
 * transparent) and inverts it via CSS filter in dark theme so it adapts
 * automatically to either color scheme.
 *
 * Variants:
 *   - "wordmark" : iD + SKILLZ, no tagline (header default)
 *   - "full"     : iD + SKILLZ + "OUR SKILLZ YOUR ID" tagline (footer / hero)
 *   - "mark"     : just the lowercase iD logomark (small contexts)
 */
interface Props {
	variant?: "mark" | "wordmark" | "full";
	class?: string;
	ariaLabel?: string;
}

const {
	variant = "wordmark",
	class: className = "",
	ariaLabel = "ID SKILLZ",
} = Astro.props;

const src = "/media/logo/id-skillz-light.png";
---

<span class:list={["brand", `brand--${variant}`, className]} role="img" aria-label={ariaLabel}>
	<img src={src} alt="" loading="eager" decoding="async" />
</span>

<style>
	.brand {
		display: inline-flex;
		align-items: center;
		justify-content: flex-start;
		/* Each variant defines its own intrinsic height below so the size is
		 * self-contained and doesn't rely on parent scoped CSS reaching the
		 * span (Astro scope hashes don't cross component boundaries, so a
		 * `.site-header__logo` rule declared in Header.astro wouldn't apply
		 * to this span). */
		flex-shrink: 0;
	}
	.brand img {
		display: block;
		height: 100%;
		width: auto;
		max-width: 100%;
		object-fit: contain;
		/* The asset is black-on-transparent; invert in dark theme */
		filter: none;
		transition: filter 0.4s var(--ease-emphatic, ease);
	}

	/* Self-sizing per variant. The source PNG is a 600×600 vertical stack:
	 *   [iD mark (top ~38%) | SKILLZ wordmark (middle ~28%) | tagline (~34%)].
	 * Heights here are the full image container height — the visible
	 * portion after each variant's clip-path is roughly:
	 *   - mark      : height × 0.38  (only the iD logomark)
	 *   - wordmark  : height × 0.64  (iD + SKILLZ, tagline clipped)
	 *   - full      : height × 1.00  (iD + SKILLZ + tagline)
	 *
	 * Previously the nav wordmark was 2.2rem → only ~22px of actual logo
	 * visible. Bumped to 3rem so ~30px of logo shows (much more readable).
	 * Previously the footer full was 4rem → tagline barely legible at
	 * ~0.55rem tall. Bumped to 6.5rem so the tagline lands at ~2.2rem
	 * which is the readability target the screenshots called for. */
	.brand--mark {
		height: 2.2rem;
	}
	.brand--wordmark {
		height: 3rem;
	}
	.brand--full {
		height: 6.5rem;
	}

	/* Dark theme (default) — invert to white */
	:global(:root[data-theme="dark"]) .brand img,
	:global(:root:not([data-theme])) .brand img {
		filter: invert(1) brightness(1.05);
	}

	@media (prefers-color-scheme: light) {
		:global(:root:not([data-theme])) .brand img {
			filter: none;
		}
	}

	:global(:root[data-theme="light"]) .brand img {
		filter: none;
	}

	.brand--mark img,
	.brand--wordmark img {
		/* The 600×600 source PNG stacks: iD mark (top ~38%) → "SKILLZ" wordmark
		 * (middle ~28%) → "OUR SKILLZ YOUR ID" tagline (bottom ~34%).
		 * Crop the bottom third aggressively so the wordmark variant truly
		 * hides the tagline (the previous 18% inset wasn't enough). */
		object-position: top;
		clip-path: inset(0 0 36% 0);
	}
	/* Mark-only variant crops even more (keeps only the iD logomark) */
	.brand--mark img {
		clip-path: inset(0 0 62% 0);
	}

	.brand--full img {
		clip-path: none;
		object-position: center;
	}
</style>
