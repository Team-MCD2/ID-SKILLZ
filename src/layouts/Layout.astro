---
import "../styles/globals.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Fab from "../components/Fab.astro";
import Preloader from "../components/Preloader.astro";
import StatusBar from "../components/StatusBar.astro";
import LenisProvider from "../components/islands/LenisProvider";
import { site } from "../lib/site";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	noindex?: boolean;
}

const {
	title = `${site.name} — Agence créative · Site web, Design, Vidéo, 3D`,
	description = site.description,
	image = "/media/logo/id-skillz-light.png",
	noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).toString();

const orgSchema = {
	"@context": "https://schema.org",
	"@type": ["Organization", "ProfessionalService"],
	"@id": `${site.url}#organization`,
	name: site.name,
	url: site.url,
	email: site.email,
	telephone: site.phoneFormatted,
	logo: `${site.url}/media/logo/id-skillz-light.png`,
	image: `${site.url}/media/logo/id-skillz-light.png`,
	description: site.description,
	founder: site.team.map((m) => ({ "@type": "Person", name: m.name, jobTitle: m.role })),
	address: [
		{
			"@type": "PostalAddress",
			addressLocality: "Paris",
			postalCode: "75008",
			streetAddress: "66 avenue des Champs-Élysées",
			addressCountry: "FR",
		},
		{
			"@type": "PostalAddress",
			addressLocality: "Colomiers",
			postalCode: "31770",
			streetAddress: "16 chemin de Garrabot",
			addressCountry: "FR",
		},
	],
	areaServed: { "@type": "Country", name: "France" },
	sameAs: [site.socials.instagram, site.socials.youtube],
	taxID: site.tva,
	vatID: site.tva,
	identifier: site.siren,
};
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		{noindex && <meta name="robots" content="noindex,nofollow" />}

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:locale" content="fr_FR" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />

		<meta name="theme-color" content="#080808" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="format-detection" content="telephone=yes" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400&family=JetBrains+Mono:wght@400;700&family=Space+Grotesk:wght@500;700;800&display=swap"
		/>
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400&family=JetBrains+Mono:wght@400;700&family=Space+Grotesk:wght@500;700;800&display=swap"
			media="print"
			onload="this.media='all'"
		/>

		<script is:inline>
			(() => {
				document.documentElement.dataset.theme = "dark";
			})();
		</script>

		<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
	</head>
	<body class="grain">
		<!-- HUD Background Shell -->
		<div class="hud-background" aria-hidden="true">
			<div class="hud-halo hud-halo--1"></div>
			<div class="hud-halo hud-halo--2"></div>
			<div class="split-grid"></div>
		</div>

		<!-- Viewport Metadata -->
		<div class="viewport-hud pointer-events-none" aria-hidden="true">
			<div class="hud-meta hud-meta--top-right">
				<div class="hud-meta__rec">
					<span class="hud-meta__dot"></span>
					REC_ACTIVE
				</div>
				<div class="hud-meta__line">RES: 3840x2160</div>
				<div class="hud-meta__line">FPS: 59.94</div>
			</div>
			<div class="hud-meta hud-meta--bottom-left">
				<div class="hud-meta__line">ENGINE_ID: SKILLZ_V2</div>
			</div>
		</div>

		<Preloader />
		<a href="#main" class="skip-link">Aller au contenu</a>
		<LenisProvider client:load />
		<Header />
		<main id="main">
			<slot />
		</main>
		<Footer />
		<Fab />
		<StatusBar />
	</body>
</html>

<style>
	.hud-background {
		position: fixed;
		inset: 0;
		background: #080808;
		z-index: -10;
		overflow: hidden;
	}

	.hud-halo {
		position: absolute;
		width: 60vw;
		height: 60vw;
		border-radius: 50%;
		filter: blur(140px);
		opacity: 0.15;
		mix-blend-mode: screen;
		pointer-events: none;
	}

	.hud-halo--1 {
		top: -10%;
		right: -10%;
		background: var(--accent);
	}

	.hud-halo--2 {
		bottom: 10%;
		left: -5%;
		background: var(--color-aubergine-soft);
		opacity: 0.08;
	}

	.viewport-hud {
		position: fixed;
		inset: 2rem;
		z-index: 90;
	}

	.hud-meta {
		position: absolute;
		font-family: var(--font-mono);
		font-size: 0.6rem;
		letter-spacing: 0.2em;
		color: var(--text-soft);
		text-transform: uppercase;
	}

	.hud-meta--top-right {
		top: 1.5rem;
		right: 0;
		text-align: right;
	}

	.hud-meta--bottom-left {
		bottom: 3rem;
		left: 0;
	}

	.hud-meta__rec {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.5rem;
		color: #ef4444;
		margin-bottom: 0.25rem;
		font-weight: 700;
	}

	.hud-meta__dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: currentColor;
		animation: pulse 1.5s ease-in-out infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.3; }
	}

	.skip-link {
		position: absolute;
		top: -100px;
		left: 1rem;
		padding: 0.5rem 1rem;
		background: var(--accent);
		color: #fff;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		z-index: 9999;
		transition: top 0.2s;
	}
	.skip-link:focus {
		top: 1rem;
	}
</style>
